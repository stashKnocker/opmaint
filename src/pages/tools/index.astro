---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
---

<Layout
	title="Maintenance Tools & Calculators | Opmaint"
	description="Free maintenance calculators: OEE, MTTR, MTBF, downtime, unit converter. Industry tools for corrugated, laundry, car wash, cold storage. No signup required."
>
    <Navbar />
    <main class="page-container">
        <div class="header-section">
            <h1>Maintenance Tools & Calculators</h1>
            <p>
                Free utilities to help maintenance professionals calculate
                essential metrics and convert common units.
            </p>
        </div>

        <!-- Maintenance Metrics Category -->
        <div class="category-section">
            <h2 class="category-title">Maintenance Metrics</h2>
            <div class="tools-grid">
            <!-- OEE Card -->
            <a href="/tools/oee-calculator" class="tool-card-link">
                <div class="tool-card">
                    <div class="tool-header">
                        <div class="icon-wrapper">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="18" y1="20" x2="18" y2="10"></line>
                                <line x1="12" y1="20" x2="12" y2="4"></line>
                                <line x1="6" y1="20" x2="6" y2="14"></line>
                            </svg>
                        </div>
                        <h2>OEE Calculator</h2>
                    </div>
                    <p class="tool-desc">
                        Calculate Overall Equipment Effectiveness (OEE) to measure manufacturing productivity by combining availability, performance, and quality.
                    </p>
                    <div class="card-footer">
                        <span>Open Calculator</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </div>
                </div>
            </a>

            <!-- MTTR Card -->
            <a href="/tools/mttr-calculator" class="tool-card-link">
                <div class="tool-card">
                    <div class="tool-header">
                        <div class="icon-wrapper">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
                            </svg>
                        </div>
                        <h2>MTTR Calculator</h2>
                    </div>
                    <p class="tool-desc">
                        Calculate Mean Time To Repair (MTTR) to track the
                        average time required to troubleshoot and repair failed
                        equipment.
                    </p>
                    <div class="card-footer">
                        <span>Open Calculator</span>
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><line x1="5" y1="12" x2="19" y2="12"
                            ></line><polyline points="12 5 19 12 12 19"
                            ></polyline>
                        </svg>
                    </div>
                </div>
            </a>

            <!-- MTBF Card -->
            <a href="/tools/mtbf-calculator" class="tool-card-link">
                <div class="tool-card">
                    <div class="tool-header">
                        <div class="icon-wrapper">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                            </svg>
                        </div>
                        <h2>MTBF Calculator</h2>
                    </div>
                    <p class="tool-desc">
                        Calculate Mean Time Between Failures (MTBF) to track the
                        predicted elapsed time between inherent failures of a
                        system.
                    </p>
                    <div class="card-footer">
                        <span>Open Calculator</span>
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><line x1="5" y1="12" x2="19" y2="12"
                            ></line><polyline points="12 5 19 12 12 19"
                            ></polyline>
                        </svg>
                    </div>
                </div>
            </a>

            <!-- Downtime Card -->
            <a href="/tools/downtime-calculator" class="tool-card-link">
                <div class="tool-card">
                    <div class="tool-header">
                        <div class="icon-wrapper">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                                <line x1="12" y1="9" x2="12" y2="13"></line>
                                <line x1="12" y1="17" x2="12.01" y2="17"></line>
                            </svg>
                        </div>
                        <h2>Downtime Calculator</h2>
                    </div>
                    <p class="tool-desc">
                        Calculate total downtime hours and its financial impact on production efficiency and costs.
                    </p>
                    <div class="card-footer">
                        <span>Open Calculator</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </div>
                </div>
            </a>

            <!-- ROI Card -->
            <a href="/tools/roi-calculator" class="tool-card-link">
                <div class="tool-card">
                    <div class="tool-header">
                        <div class="icon-wrapper">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="12" y1="1" x2="12" y2="23"></line>
                                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                            </svg>
                        </div>
                        <h2>ROI Calculator</h2>
                    </div>
                    <p class="tool-desc">
                        Calculate return on investment for maintenance projects, equipment purchases, or process improvements to justify investments.
                    </p>
                    <div class="card-footer">
                        <span>Open Calculator</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </div>
                </div>
            </a>
            </div>
        </div>

        <!-- Unit Conversion Category -->
        <div class="category-section">
            <h2 class="category-title">Unit Conversion</h2>
            <div class="tools-grid">
            <!-- Unit Conversion Card -->
            <a href="/tools/unit-converter" class="tool-card-link">
                <div class="tool-card">
                    <div class="tool-header">
                        <div class="icon-wrapper">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 18 15 12 9 6"></polyline>
                                <polyline points="15 18 9 12 15 6"></polyline>
                            </svg>
                        </div>
                        <h2>Maintenance Unit Converter</h2>
                    </div>
                    <p class="tool-desc">
                        Quickly convert common units used in factory floors,
                        facilities, and machine maintenance across Energy,
                        Pressure, Power, and more.
                    </p>
                    <div class="card-footer">
                        <span>Open Converter</span>
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><line x1="5" y1="12" x2="19" y2="12"
                            ></line><polyline points="12 5 19 12 12 19"
                            ></polyline>
                        </svg>
                    </div>
                </div>
            </a>
            </div>
        </div>

        <!-- Industry-Specific Calculators Category -->
        <div class="category-section">
            <h2 class="category-title">Industry-Specific Calculators</h2>
            <div class="tools-grid">
            <!-- Corrugated Box Yield Card -->
            <a href="/tools/corrugated-box-yield-calculator" class="tool-card-link">
                <div class="tool-card">
                    <div class="tool-header">
                        <div class="icon-wrapper">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                                <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                                <line x1="12" y1="22.08" x2="12" y2="12"></line>
                            </svg>
                        </div>
                        <h2>Corrugated Box Yield Calculator</h2>
                    </div>
                    <p class="tool-desc">
                        Calculate the yield percentage for corrugated box production to optimize material usage and identify waste.
                    </p>
                    <div class="card-footer">
                        <span>Open Calculator</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </div>
                </div>
            </a>

            <!-- Laundry Throughput Card -->
            <a href="/tools/laundry-throughput-calculator" class="tool-card-link">
                <div class="tool-card">
                    <div class="tool-header">
                        <div class="icon-wrapper">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <path d="M12 6v6l4 2"></path>
                            </svg>
                        </div>
                        <h2>Laundry Throughput Calculator</h2>
                    </div>
                    <p class="tool-desc">
                        Calculate daily throughput capacity for laundry operations to optimize machine utilization and plan production schedules.
                    </p>
                    <div class="card-footer">
                        <span>Open Calculator</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </div>
                </div>
            </a>

            <!-- Car Wash Revenue Card -->
            <a href="/tools/car-wash-revenue-calculator" class="tool-card-link">
                <div class="tool-card">
                    <div class="tool-header">
                        <div class="icon-wrapper">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 17H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-1"></path>
                                <polygon points="12 15 17 21 7 21 12 15"></polygon>
                            </svg>
                        </div>
                        <h2>Car Wash Revenue Calculator</h2>
                    </div>
                    <p class="tool-desc">
                        Calculate potential revenue for car wash operations based on wash volume, pricing tiers, and operating hours.
                    </p>
                    <div class="card-footer">
                        <span>Open Calculator</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </div>
                </div>
            </a>

            <!-- Cold Storage Energy Card -->
            <a href="/tools/cold-storage-energy-calculator" class="tool-card-link">
                <div class="tool-card">
                    <div class="tool-header">
                        <div class="icon-wrapper">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0z"></path>
                            </svg>
                        </div>
                        <h2>Cold Storage Energy Calculator</h2>
                    </div>
                    <p class="tool-desc">
                        Calculate energy consumption and operating costs for cold storage facilities to optimize energy usage and budget.
                    </p>
                    <div class="card-footer">
                        <span>Open Calculator</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </div>
                </div>
            </a>
            </div>
        </div>
    </main>
</Layout>

<style>
    .page-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 4rem 2rem;
    }

    .header-section {
        margin-bottom: 4rem;
        text-align: center;
    }

    .header-section h1 {
        font-size: 3rem;
        color: #111827;
        margin: 0 0 1rem;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    .header-section p {
        font-size: 1.25rem;
        color: #6b7280;
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.6;
    }

    .category-section {
        margin-bottom: 4rem;
    }

    .category-section:last-child {
        margin-bottom: 0;
    }

    .category-title {
        font-size: 1.75rem;
        color: #111827;
        margin: 0 0 2rem 0;
        font-weight: 700;
        font-family: "Switzer", sans-serif;
        border-bottom: 2px solid #eaeaea;
        padding-bottom: 0.75rem;
    }

    .tools-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 2rem;
    }

    .tool-card-link {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
    }

    .tool-card {
        background: white;
        border: 1px solid #eaeaea;
        border-radius: 16px;
        padding: 2.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        display: flex;
        flex-direction: column;
        flex: 1;
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    }

    .tool-card-link:hover .tool-card {
        transform: translateY(-4px);
        box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.08);
        border-color: #cdd5f2;
    }

    .tool-card.disabled {
        background: #f8fafc;
        border-style: dashed;
        cursor: not-allowed;
    }

    .tool-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .icon-wrapper {
        width: 48px;
        height: 48px;
        background: #ebedfa;
        color: #345ebd;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .tool-header h2 {
        font-size: 1.4rem;
        margin: 0;
        color: #111827;
        font-weight: 700;
    }

    .tool-desc {
        color: #4b5563;
        margin: 0 0 2.5rem 0;
        line-height: 1.6;
        font-size: 1.05rem;
        flex-grow: 1;
    }

    .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: #345ebd;
        font-weight: 600;
        font-size: 1.05rem;
    }

    .tool-card-link:hover .card-footer svg {
        transform: translateX(4px);
    }

    .card-footer svg {
        transition: transform 0.2s ease;
    }

    @media screen and (max-width: 768px) {
        .header-section h1 {
            font-size: 2.25rem;
        }

        .category-title {
            font-size: 1.5rem;
        }

        .tools-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
