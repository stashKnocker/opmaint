---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
---

<Layout
	title="MTTR Calculator - Mean Time To Repair | Opmaint"
	description="Calculate MTTR (Mean Time To Repair) to track average repair time for failed equipment. Free maintenance metric calculator."
>
    <Navbar />
    <main class="page-container">
        <a href="/tools" class="back-link">
            <svg
                class="arrow"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to all tools
        </a>

        <div class="tool-wrapper">
            <div class="tool-header">
                <div class="icon-wrapper">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
                    </svg>
                </div>
                <div>
                    <h1>MTTR Calculator</h1>
                    <p class="tool-subtitle">Mean Time To Repair</p>
                </div>
            </div>

            <p class="tool-desc">
                MTTR (Mean Time To Repair) is the average time required to
                troubleshoot and repair failed equipment and return it to normal
                operating conditions. It provides a measure of maintainability.
            </p>

            <div class="calculator-card">
                <div class="calculator-form">
                    <div class="input-group">
                        <label for="mttr-time"
                            >Total Maintenance Time (Hours)</label
                        >
                        <input
                            type="number"
                            id="mttr-time"
                            min="0"
                            step="0.1"
                            placeholder="e.g., 45"
                        />
                    </div>
                    <div class="input-group">
                        <label for="mttr-repairs">Total Number of Repairs</label
                        >
                        <input
                            type="number"
                            id="mttr-repairs"
                            min="1"
                            step="1"
                            placeholder="e.g., 5"
                        />
                    </div>
                    <button id="calc-mttr" class="calc-btn"
                        >Calculate MTTR</button
                    >

                    <div
                        class="result-box"
                        id="mttr-result-box"
                        style="display: none;"
                    >
                        <span class="result-label">MTTR</span>
                        <span class="result-value" id="mttr-result"
                            >0 Hours</span
                        >
                    </div>
                </div>
            </div>

            <div class="formula-section">
                <h3>How is MTTR Calculated?</h3>
                <div class="formula-box">
                    <span>MTTR</span> = <span>Total Maintenance Time</span> &divide;
                    <span>Total Number of Repairs</span>
                </div>
            </div>
        </div>
    </main>
</Layout>

<script>
    document.getElementById("calc-mttr")?.addEventListener("click", () => {
        const time = parseFloat(
            (document.getElementById("mttr-time") as HTMLInputElement).value
        );
        const repairs = parseInt(
            (document.getElementById("mttr-repairs") as HTMLInputElement).value
        );

        if (time >= 0 && repairs > 0) {
            const mttr = (time / repairs).toFixed(2);
            const resultBox = document.getElementById("mttr-result-box");
            const resultVal = document.getElementById("mttr-result");
            if (resultBox && resultVal) {
                resultVal.textContent = `${mttr} Hours`;
                resultBox.style.display = "flex";
            }
        } else {
            alert(
                "Please enter valid positive numbers. Repairs must be greater than 0."
            );
        }
    });
</script>

<style>
    .page-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 4rem 2rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #6b7280;
        text-decoration: none;
        font-weight: 500;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: #111827;
    }

    .back-link .arrow {
        transition: transform 0.2s;
    }

    .back-link:hover .arrow {
        transform: translateX(-4px);
    }

    .tool-wrapper {
        background: white;
        border-radius: 16px;
        padding: 0;
    }

    .tool-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
    }

    .icon-wrapper {
        width: 64px;
        height: 64px;
        background: #ebedfa;
        color: #345ebd;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    h1 {
        font-size: 2.5rem;
        color: #111827;
        margin: 0;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    .tool-subtitle {
        color: #345ebd;
        font-weight: 600;
        font-size: 1.1rem;
        margin: 0.25rem 0 0 0;
    }

    .tool-desc {
        color: #4b5563;
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 2.5rem;
    }

    .calculator-card {
        background: white;
        border: 1px solid #eaeaea;
        border-radius: 12px;
        padding: 2.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        margin-bottom: 3rem;
    }

    .calculator-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .input-group label {
        font-weight: 600;
        font-size: 0.95rem;
        color: #374151;
    }

    .input-group input {
        padding: 0.8rem 1rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-family: inherit;
        font-size: 1.1rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .input-group input:focus {
        border-color: #345ebd;
        box-shadow: 0 0 0 3px rgba(52, 94, 189, 0.1);
    }

    .calc-btn {
        background: #345ebd;
        color: white;
        border: none;
        padding: 1.2rem;
        border-radius: 8px;
        font-family: inherit;
        font-weight: 600;
        font-size: 1.1rem;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 0.5rem;
    }

    .calc-btn:hover {
        background: #2b4a92;
    }

    .result-box {
        margin-top: 1rem;
        background: #ebedfa;
        border: 1px solid #cdd5f2;
        border-radius: 8px;
        padding: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .result-label {
        font-weight: 700;
        color: #345ebd;
        font-size: 1.2rem;
    }

    .result-value {
        font-weight: 800;
        color: #345ebd;
        font-size: 1.8rem;
    }

    .formula-section {
        background: #f8fafc;
        border-radius: 12px;
        padding: 2rem;
        border: 1px solid #eaeaea;
    }

    .formula-section h3 {
        font-size: 1.25rem;
        color: #111827;
        margin: 0 0 1.5rem 0;
        font-weight: 700;
    }

    .formula-box {
        background: white;
        border-radius: 8px;
        padding: 1.5rem;
        font-size: 1.15rem;
        color: #1f2937;
        text-align: center;
        border: 1px solid #e2e8f0;
        line-height: 1.8;
        font-family: "DM Sans", sans-serif;
    }

    .formula-box span {
        font-weight: 600;
        color: #345ebd;
        padding: 0 0.25rem;
    }

    @media screen and (max-width: 768px) {
        .page-container {
            padding: 2rem 1rem;
        }

        .tool-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }

        .calculator-card {
            padding: 1.5rem;
        }
    }
</style>
