---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
---

<Layout
	title="Laundry Throughput Calculator | Opmaint"
	description="Calculate daily laundry throughput capacity to optimize machine utilization and plan production schedules."
>
    <Navbar />
    <main class="page-container">
        <a href="/tools" class="back-link">
            <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to all tools
        </a>

        <div class="tool-wrapper">
            <div class="tool-header">
                <div class="icon-wrapper">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                    </svg>
                </div>
                <div>
                    <h1>Laundry Throughput Calculator</h1>
                    <p class="tool-subtitle">Calculate Processing Capacity</p>
                </div>
            </div>

            <p class="tool-desc">
                Calculate daily throughput capacity for laundry operations. Helps optimize machine utilization and plan production schedules.
            </p>

            <div class="calculator-card">
                <div class="calculator-form">
                    <div class="input-group">
                        <label for="machines">Number of Machines</label>
                        <input type="number" id="machines" min="1" step="1" placeholder="e.g., 10" />
                    </div>
                    <div class="input-group">
                        <label for="cycles-per-hour">Cycles per Hour per Machine</label>
                        <input type="number" id="cycles-per-hour" min="0" step="0.1" placeholder="e.g., 2.5" />
                    </div>
                    <div class="input-group">
                        <label for="load-size">Load Size (lbs or kg)</label>
                        <input type="number" id="load-size" min="0" step="0.1" placeholder="e.g., 50" />
                    </div>
                    <div class="input-group">
                        <label for="operating-hours">Operating Hours per Day</label>
                        <input type="number" id="operating-hours" min="0" max="24" step="0.5" placeholder="e.g., 16" />
                    </div>
                    <button id="calc-throughput" class="calc-btn">Calculate Throughput</button>

                    <div class="result-box" id="throughput-result-box" style="display: none;">
                        <div>
                            <span class="result-label">Daily Throughput</span>
                            <span class="result-value" id="daily-throughput">0 units</span>
                        </div>
                        <div>
                            <span class="result-label">Hourly Capacity</span>
                            <span class="result-value" id="hourly-capacity">0 units/hour</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="formula-section">
                <h3>How is Throughput Calculated?</h3>
                <div class="formula-box">
                    <div><span>Hourly Capacity</span> = <span>Machines</span> × <span>Cycles/Hour</span> × <span>Load Size</span></div>
                    <div style="margin-top: 1rem;"><span>Daily Throughput</span> = <span>Hourly Capacity</span> × <span>Operating Hours</span></div>
                </div>
            </div>
        </div>
    </main>
</Layout>

<script>
    document.getElementById("calc-throughput")?.addEventListener("click", () => {
        const machines = parseFloat((document.getElementById("machines") as HTMLInputElement).value);
        const cycles = parseFloat((document.getElementById("cycles-per-hour") as HTMLInputElement).value);
        const loadSize = parseFloat((document.getElementById("load-size") as HTMLInputElement).value);
        const hours = parseFloat((document.getElementById("operating-hours") as HTMLInputElement).value);

        if (machines > 0 && cycles >= 0 && loadSize >= 0 && hours >= 0 && hours <= 24) {
            const hourlyCapacity = (machines * cycles * loadSize).toFixed(2);
            const dailyThroughput = (parseFloat(hourlyCapacity) * hours).toFixed(2);
            const resultBox = document.getElementById("throughput-result-box");
            const hourlyEl = document.getElementById("hourly-capacity");
            const dailyEl = document.getElementById("daily-throughput");
            if (resultBox && hourlyEl && dailyEl) {
                hourlyEl.textContent = `${hourlyCapacity} units/hour`;
                dailyEl.textContent = `${dailyThroughput} units`;
                resultBox.style.display = "flex";
            }
        } else {
            alert("Please enter valid numbers. Machines must be greater than 0, and operating hours must be between 0 and 24.");
        }
    });
</script>

<style>
    .page-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 4rem 2rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #6b7280;
        text-decoration: none;
        font-weight: 500;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: #111827;
    }

    .tool-wrapper {
        background: white;
        border-radius: 16px;
        padding: 0;
    }

    .tool-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
    }

    .icon-wrapper {
        width: 64px;
        height: 64px;
        background: #ebedfa;
        color: #345ebd;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    h1 {
        font-size: 2.5rem;
        color: #111827;
        margin: 0;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    .tool-subtitle {
        color: #345ebd;
        font-weight: 600;
        font-size: 1.1rem;
        margin: 0.25rem 0 0 0;
    }

    .tool-desc {
        color: #4b5563;
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 2.5rem;
    }

    .calculator-card {
        background: white;
        border: 1px solid #eaeaea;
        border-radius: 12px;
        padding: 2.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        margin-bottom: 3rem;
    }

    .calculator-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .input-group label {
        font-weight: 600;
        font-size: 0.95rem;
        color: #374151;
    }

    .input-group input {
        padding: 0.8rem 1rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-family: inherit;
        font-size: 1.1rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .input-group input:focus {
        border-color: #345ebd;
        box-shadow: 0 0 0 3px rgba(52, 94, 189, 0.1);
    }

    .calc-btn {
        background: #345ebd;
        color: white;
        border: none;
        padding: 1.2rem;
        border-radius: 8px;
        font-family: inherit;
        font-weight: 600;
        font-size: 1.1rem;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 0.5rem;
    }

    .calc-btn:hover {
        background: #2b4a92;
    }

    .result-box {
        margin-top: 1rem;
        background: #ebedfa;
        border: 1px solid #cdd5f2;
        border-radius: 8px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .result-box > div {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .result-label {
        font-weight: 700;
        color: #345ebd;
        font-size: 1.2rem;
    }

    .result-value {
        font-weight: 800;
        color: #345ebd;
        font-size: 1.8rem;
    }

    .formula-section {
        background: #f8fafc;
        border-radius: 12px;
        padding: 2rem;
        border: 1px solid #eaeaea;
    }

    .formula-section h3 {
        font-size: 1.25rem;
        color: #111827;
        margin: 0 0 1.5rem 0;
        font-weight: 700;
    }

    .formula-box {
        background: white;
        border-radius: 8px;
        padding: 1.5rem;
        font-size: 1.15rem;
        color: #1f2937;
        text-align: center;
        border: 1px solid #e2e8f0;
        line-height: 1.8;
        font-family: "DM Sans", sans-serif;
    }

    .formula-box span {
        font-weight: 600;
        color: #345ebd;
        padding: 0 0.25rem;
    }

    .formula-box div {
        margin-bottom: 0.5rem;
    }

    .formula-box div:last-child {
        margin-bottom: 0;
    }

    @media screen and (max-width: 768px) {
        .page-container {
            padding: 2rem 1rem;
        }

        .tool-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }

        .calculator-card {
            padding: 1.5rem;
        }
    }
</style>
