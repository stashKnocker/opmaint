---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
---

<Layout
	title="OEE Calculator - Overall Equipment Effectiveness | Opmaint"
	description="Calculate OEE (Overall Equipment Effectiveness) from availability, performance, and quality. Free OEE calculator for manufacturing productivity metrics."
>
    <Navbar />
    <main class="page-container">
        <a href="/tools" class="back-link">
            <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to all tools
        </a>

        <div class="tool-wrapper">
            <div class="tool-header">
                <div class="icon-wrapper">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                </div>
                <div>
                    <h1>OEE Calculator</h1>
                    <p class="tool-subtitle">Overall Equipment Effectiveness</p>
                </div>
            </div>

            <p class="tool-desc">
                OEE (Overall Equipment Effectiveness) measures manufacturing productivity by combining availability, performance, and quality metrics. A world-class OEE score is typically 85% or higher.
            </p>

            <div class="calculator-card">
                <div class="calculator-form">
                    <div class="input-group">
                        <label for="availability">Availability (%)</label>
                        <input type="number" id="availability" min="0" max="100" step="0.1" placeholder="e.g., 90" />
                        <small>Actual production time / Planned production time</small>
                    </div>
                    <div class="input-group">
                        <label for="performance">Performance (%)</label>
                        <input type="number" id="performance" min="0" max="100" step="0.1" placeholder="e.g., 85" />
                        <small>Actual output / Ideal output</small>
                    </div>
                    <div class="input-group">
                        <label for="quality">Quality (%)</label>
                        <input type="number" id="quality" min="0" max="100" step="0.1" placeholder="e.g., 95" />
                        <small>Good parts / Total parts produced</small>
                    </div>
                    <button id="calc-oee" class="calc-btn">Calculate OEE</button>

                    <div class="result-box" id="oee-result-box" style="display: none;">
                        <span class="result-label">OEE</span>
                        <span class="result-value" id="oee-result">0%</span>
                    </div>
                </div>
            </div>

            <div class="formula-section">
                <h3>How is OEE Calculated?</h3>
                <div class="formula-box">
                    <span>OEE</span> = <span>Availability</span> × <span>Performance</span> × <span>Quality</span>
                </div>
                <p class="formula-note">All values are expressed as percentages (0-100).</p>
            </div>
        </div>
    </main>
</Layout>

<script>
    document.getElementById("calc-oee")?.addEventListener("click", () => {
        const availability = parseFloat((document.getElementById("availability") as HTMLInputElement).value) / 100;
        const performance = parseFloat((document.getElementById("performance") as HTMLInputElement).value) / 100;
        const quality = parseFloat((document.getElementById("quality") as HTMLInputElement).value) / 100;

        if (availability >= 0 && availability <= 1 && performance >= 0 && performance <= 1 && quality >= 0 && quality <= 1) {
            const oee = (availability * performance * quality * 100).toFixed(2);
            const resultBox = document.getElementById("oee-result-box");
            const resultVal = document.getElementById("oee-result");
            if (resultBox && resultVal) {
                resultVal.textContent = `${oee}%`;
                resultBox.style.display = "flex";
            }
        } else {
            alert("Please enter valid percentages (0-100).");
        }
    });
</script>

<style>
    .page-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 4rem 2rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #6b7280;
        text-decoration: none;
        font-weight: 500;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: #111827;
    }

    .tool-wrapper {
        background: white;
        border-radius: 16px;
        padding: 0;
    }

    .tool-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
    }

    .icon-wrapper {
        width: 64px;
        height: 64px;
        background: #ebedfa;
        color: #345ebd;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    h1 {
        font-size: 2.5rem;
        color: #111827;
        margin: 0;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    .tool-subtitle {
        color: #345ebd;
        font-weight: 600;
        font-size: 1.1rem;
        margin: 0.25rem 0 0 0;
    }

    .tool-desc {
        color: #4b5563;
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 2.5rem;
    }

    .calculator-card {
        background: white;
        border: 1px solid #eaeaea;
        border-radius: 12px;
        padding: 2.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        margin-bottom: 3rem;
    }

    .calculator-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .input-group label {
        font-weight: 600;
        font-size: 0.95rem;
        color: #374151;
    }

    .input-group input {
        padding: 0.8rem 1rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-family: inherit;
        font-size: 1.1rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .input-group input:focus {
        border-color: #345ebd;
        box-shadow: 0 0 0 3px rgba(52, 94, 189, 0.1);
    }

    .input-group small {
        color: #6b7280;
        font-size: 0.85rem;
    }

    .calc-btn {
        background: #345ebd;
        color: white;
        border: none;
        padding: 1.2rem;
        border-radius: 8px;
        font-family: inherit;
        font-weight: 600;
        font-size: 1.1rem;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 0.5rem;
    }

    .calc-btn:hover {
        background: #2b4a92;
    }

    .result-box {
        margin-top: 1rem;
        background: #ebedfa;
        border: 1px solid #cdd5f2;
        border-radius: 8px;
        padding: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .result-label {
        font-weight: 700;
        color: #345ebd;
        font-size: 1.2rem;
    }

    .result-value {
        font-weight: 800;
        color: #345ebd;
        font-size: 1.8rem;
    }

    .formula-section {
        background: #f8fafc;
        border-radius: 12px;
        padding: 2rem;
        border: 1px solid #eaeaea;
    }

    .formula-section h3 {
        font-size: 1.25rem;
        color: #111827;
        margin: 0 0 1.5rem 0;
        font-weight: 700;
    }

    .formula-box {
        background: white;
        border-radius: 8px;
        padding: 1.5rem;
        font-size: 1.15rem;
        color: #1f2937;
        text-align: center;
        border: 1px solid #e2e8f0;
        line-height: 1.8;
        font-family: "DM Sans", sans-serif;
    }

    .formula-box span {
        font-weight: 600;
        color: #345ebd;
        padding: 0 0.25rem;
    }

    .formula-box div {
        margin-bottom: 0.5rem;
    }

    .formula-box div:last-child {
        margin-bottom: 0;
    }

    .formula-note {
        margin-top: 0.75rem;
        color: #6b7280;
        font-size: 0.9rem;
        text-align: center;
    }

    @media screen and (max-width: 768px) {
        .page-container {
            padding: 2rem 1rem;
        }

        .tool-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }

        .calculator-card {
            padding: 1.5rem;
        }
    }
</style>
