---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
---

<Layout
	title="Downtime Calculator - Production Downtime & Cost | Opmaint"
	description="Calculate total downtime hours and financial impact on production. Free downtime calculator for maintenance planning."
>
    <Navbar />
    <main class="page-container">
        <a href="/tools" class="back-link">
            <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to all tools
        </a>

        <div class="tool-wrapper">
            <div class="tool-header">
                <div class="icon-wrapper">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                        <line x1="12" y1="9" x2="12" y2="13"></line>
                        <line x1="12" y1="17" x2="12.01" y2="17"></line>
                    </svg>
                </div>
                <div>
                    <h1>Downtime Calculator</h1>
                    <p class="tool-subtitle">Calculate Production Downtime Impact</p>
                </div>
            </div>

            <p class="tool-desc">
                Calculate total downtime hours and its financial impact on production. Helps quantify the cost of equipment failures and maintenance delays.
            </p>

            <div class="calculator-card">
                <div class="calculator-form">
                    <div class="input-group">
                        <label for="downtime-hours">Total Downtime (Hours)</label>
                        <input type="number" id="downtime-hours" min="0" step="0.1" placeholder="e.g., 24" />
                    </div>
                    <div class="input-group">
                        <label for="hourly-rate">Hourly Production Rate (Units/Hour)</label>
                        <input type="number" id="hourly-rate" min="0" step="0.1" placeholder="e.g., 100" />
                    </div>
                    <div class="input-group">
                        <label for="unit-value">Unit Value ($)</label>
                        <input type="number" id="unit-value" min="0" step="0.01" placeholder="e.g., 5.50" />
                    </div>
                    <button id="calc-downtime" class="calc-btn">Calculate Impact</button>

                    <div class="result-box" id="downtime-result-box" style="display: none;">
                        <div>
                            <span class="result-label">Lost Production</span>
                            <span class="result-value" id="lost-units">0 units</span>
                        </div>
                        <div>
                            <span class="result-label">Financial Impact</span>
                            <span class="result-value" id="lost-revenue">$0</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="formula-section">
                <h3>How is Downtime Calculated?</h3>
                <div class="formula-box">
                    <div><span>Lost Production</span> = <span>Downtime Hours</span> × <span>Hourly Rate</span></div>
                    <div style="margin-top: 1rem;"><span>Financial Impact</span> = <span>Lost Production</span> × <span>Unit Value</span></div>
                </div>
            </div>
        </div>
    </main>
</Layout>

<script>
    document.getElementById("calc-downtime")?.addEventListener("click", () => {
        const hours = parseFloat((document.getElementById("downtime-hours") as HTMLInputElement).value);
        const rate = parseFloat((document.getElementById("hourly-rate") as HTMLInputElement).value);
        const value = parseFloat((document.getElementById("unit-value") as HTMLInputElement).value);

        if (hours >= 0 && rate >= 0 && value >= 0) {
            const lostUnits = (hours * rate).toFixed(2);
            const lostRevenue = (parseFloat(lostUnits) * value).toFixed(2);
            const resultBox = document.getElementById("downtime-result-box");
            const lostUnitsEl = document.getElementById("lost-units");
            const lostRevenueEl = document.getElementById("lost-revenue");
            if (resultBox && lostUnitsEl && lostRevenueEl) {
                lostUnitsEl.textContent = `${lostUnits} units`;
                lostRevenueEl.textContent = `$${parseFloat(lostRevenue).toLocaleString()}`;
                resultBox.style.display = "flex";
            }
        } else {
            alert("Please enter valid positive numbers.");
        }
    });
</script>

<style>
    .page-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 4rem 2rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #6b7280;
        text-decoration: none;
        font-weight: 500;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: #111827;
    }

    .tool-wrapper {
        background: white;
        border-radius: 16px;
        padding: 0;
    }

    .tool-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
    }

    .icon-wrapper {
        width: 64px;
        height: 64px;
        background: #ebedfa;
        color: #345ebd;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    h1 {
        font-size: 2.5rem;
        color: #111827;
        margin: 0;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    .tool-subtitle {
        color: #345ebd;
        font-weight: 600;
        font-size: 1.1rem;
        margin: 0.25rem 0 0 0;
    }

    .tool-desc {
        color: #4b5563;
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 2.5rem;
    }

    .calculator-card {
        background: white;
        border: 1px solid #eaeaea;
        border-radius: 12px;
        padding: 2.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        margin-bottom: 3rem;
    }

    .calculator-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .input-group label {
        font-weight: 600;
        font-size: 0.95rem;
        color: #374151;
    }

    .input-group input {
        padding: 0.8rem 1rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-family: inherit;
        font-size: 1.1rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .input-group input:focus {
        border-color: #345ebd;
        box-shadow: 0 0 0 3px rgba(52, 94, 189, 0.1);
    }

    .calc-btn {
        background: #345ebd;
        color: white;
        border: none;
        padding: 1.2rem;
        border-radius: 8px;
        font-family: inherit;
        font-weight: 600;
        font-size: 1.1rem;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 0.5rem;
    }

    .calc-btn:hover {
        background: #2b4a92;
    }

    .result-box {
        margin-top: 1rem;
        background: #ebedfa;
        border: 1px solid #cdd5f2;
        border-radius: 8px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .result-box > div {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .result-label {
        font-weight: 700;
        color: #345ebd;
        font-size: 1.2rem;
    }

    .result-value {
        font-weight: 800;
        color: #345ebd;
        font-size: 1.8rem;
    }

    .formula-section {
        background: #f8fafc;
        border-radius: 12px;
        padding: 2rem;
        border: 1px solid #eaeaea;
    }

    .formula-section h3 {
        font-size: 1.25rem;
        color: #111827;
        margin: 0 0 1.5rem 0;
        font-weight: 700;
    }

    .formula-box {
        background: white;
        border-radius: 8px;
        padding: 1.5rem;
        font-size: 1.15rem;
        color: #1f2937;
        text-align: center;
        border: 1px solid #e2e8f0;
        line-height: 1.8;
        font-family: "DM Sans", sans-serif;
    }

    .formula-box span {
        font-weight: 600;
        color: #345ebd;
        padding: 0 0.25rem;
    }

    .formula-box div {
        margin-bottom: 0.5rem;
    }

    .formula-box div:last-child {
        margin-bottom: 0;
    }

    @media screen and (max-width: 768px) {
        .page-container {
            padding: 2rem 1rem;
        }

        .tool-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }

        .calculator-card {
            padding: 1.5rem;
        }
    }
</style>
