---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
---

<Layout
	title="Corrugated Box Yield Calculator | Opmaint"
	description="Calculate corrugated box yield percentage to optimize material usage and reduce waste in box production."
>
    <Navbar />
    <main class="page-container">
        <a href="/tools" class="back-link">
            <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to all tools
        </a>

        <div class="tool-wrapper">
            <div class="tool-header">
                <div class="icon-wrapper">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    </svg>
                </div>
                <div>
                    <h1>Corrugated Box Yield Calculator</h1>
                    <p class="tool-subtitle">Calculate Box Production Efficiency</p>
                </div>
            </div>

            <p class="tool-desc">
                Calculate the yield percentage for corrugated box production. Helps optimize material usage and identify waste in the manufacturing process.
            </p>

            <div class="calculator-card">
                <div class="calculator-form">
                    <div class="input-group">
                        <label for="total-boxes">Total Boxes Produced</label>
                        <input type="number" id="total-boxes" min="0" step="1" placeholder="e.g., 10000" />
                    </div>
                    <div class="input-group">
                        <label for="good-boxes">Good Quality Boxes</label>
                        <input type="number" id="good-boxes" min="0" step="1" placeholder="e.g., 9500" />
                    </div>
                    <div class="input-group">
                        <label for="material-used">Material Used (sq ft or sq m)</label>
                        <input type="number" id="material-used" min="0" step="0.01" placeholder="e.g., 5000" />
                    </div>
                    <button id="calc-yield" class="calc-btn">Calculate Yield</button>

                    <div class="result-box" id="yield-result-box" style="display: none;">
                        <div>
                            <span class="result-label">Quality Yield</span>
                            <span class="result-value" id="quality-yield">0%</span>
                        </div>
                        <div>
                            <span class="result-label">Material Efficiency</span>
                            <span class="result-value" id="material-efficiency">0 boxes/unit</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="formula-section">
                <h3>How is Yield Calculated?</h3>
                <div class="formula-box">
                    <div><span>Quality Yield</span> = (<span>Good Boxes</span> / <span>Total Boxes</span>) × 100%</div>
                    <div style="margin-top: 1rem;"><span>Material Efficiency</span> = <span>Good Boxes</span> / <span>Material Used</span></div>
                </div>
            </div>
        </div>
    </main>
</Layout>

<script>
    document.getElementById("calc-yield")?.addEventListener("click", () => {
        const total = parseFloat((document.getElementById("total-boxes") as HTMLInputElement).value);
        const good = parseFloat((document.getElementById("good-boxes") as HTMLInputElement).value);
        const material = parseFloat((document.getElementById("material-used") as HTMLInputElement).value);

        if (total >= 0 && good >= 0 && material > 0 && good <= total) {
            const qualityYield = ((good / total) * 100).toFixed(2);
            const materialEff = (good / material).toFixed(2);
            const resultBox = document.getElementById("yield-result-box");
            const qualityEl = document.getElementById("quality-yield");
            const materialEl = document.getElementById("material-efficiency");
            if (resultBox && qualityEl && materialEl) {
                qualityEl.textContent = `${qualityYield}%`;
                materialEl.textContent = `${materialEff} boxes/unit`;
                resultBox.style.display = "flex";
            }
        } else {
            alert("Please enter valid numbers. Good boxes cannot exceed total boxes, and material used must be greater than 0.");
        }
    });
</script>

<style>
    .page-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 4rem 2rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #6b7280;
        text-decoration: none;
        font-weight: 500;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: #111827;
    }

    .tool-wrapper {
        background: white;
        border-radius: 16px;
        padding: 0;
    }

    .tool-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
    }

    .icon-wrapper {
        width: 64px;
        height: 64px;
        background: #ebedfa;
        color: #345ebd;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    h1 {
        font-size: 2.5rem;
        color: #111827;
        margin: 0;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    .tool-subtitle {
        color: #345ebd;
        font-weight: 600;
        font-size: 1.1rem;
        margin: 0.25rem 0 0 0;
    }

    .tool-desc {
        color: #4b5563;
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 2.5rem;
    }

    .calculator-card {
        background: white;
        border: 1px solid #eaeaea;
        border-radius: 12px;
        padding: 2.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        margin-bottom: 3rem;
    }

    .calculator-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .input-group label {
        font-weight: 600;
        font-size: 0.95rem;
        color: #374151;
    }

    .input-group input {
        padding: 0.8rem 1rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-family: inherit;
        font-size: 1.1rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .input-group input:focus {
        border-color: #345ebd;
        box-shadow: 0 0 0 3px rgba(52, 94, 189, 0.1);
    }

    .calc-btn {
        background: #345ebd;
        color: white;
        border: none;
        padding: 1.2rem;
        border-radius: 8px;
        font-family: inherit;
        font-weight: 600;
        font-size: 1.1rem;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 0.5rem;
    }

    .calc-btn:hover {
        background: #2b4a92;
    }

    .result-box {
        margin-top: 1rem;
        background: #ebedfa;
        border: 1px solid #cdd5f2;
        border-radius: 8px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .result-box > div {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .result-label {
        font-weight: 700;
        color: #345ebd;
        font-size: 1.2rem;
    }

    .result-value {
        font-weight: 800;
        color: #345ebd;
        font-size: 1.8rem;
    }

    .formula-section {
        background: #f8fafc;
        border-radius: 12px;
        padding: 2rem;
        border: 1px solid #eaeaea;
    }

    .formula-section h3 {
        font-size: 1.25rem;
        color: #111827;
        margin: 0 0 1.5rem 0;
        font-weight: 700;
    }

    .formula-box {
        background: white;
        border-radius: 8px;
        padding: 1.5rem;
        font-size: 1.15rem;
        color: #1f2937;
        text-align: center;
        border: 1px solid #e2e8f0;
        line-height: 1.8;
        font-family: "DM Sans", sans-serif;
    }

    .formula-box span {
        font-weight: 600;
        color: #345ebd;
        padding: 0 0.25rem;
    }

    .formula-box div {
        margin-bottom: 0.5rem;
    }

    .formula-box div:last-child {
        margin-bottom: 0;
    }

    @media screen and (max-width: 768px) {
        .page-container {
            padding: 2rem 1rem;
        }

        .tool-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }

        .calculator-card {
            padding: 1.5rem;
        }
    }
</style>
