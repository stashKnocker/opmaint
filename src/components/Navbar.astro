---
// Navbar component – links aligned with www.opmaint.com
const baseUrl = "https://www.opmaint.com";
const appUrl = "https://app.opmaint.com";
---

<nav class="navbar">
    <div class="nav-left">
        <a href={baseUrl} class="logo">
            <img
                src="/images/opmaint-logo-white.svg"
                alt="Opmaint"
                class="brand-logo"
                width="147"
                height="37"
            />
        </a>
    </div>

    <div class="nav-center">
        <div class="nav-dropdown">
            <a href={`${baseUrl}/cmms-software`} class="nav-link">
                Products
                <svg
                    class="chevron"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                >
                    <path
                        fill-rule="evenodd"
                        d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                        clip-rule="evenodd"></path>
                </svg>
            </a>
            <div class="dropdown-menu">
                <a href={`${baseUrl}/use-cases/asset-management`}>Asset Management</a>
                <a href={`${baseUrl}/use-cases/preventive-maintenance`}>Preventive Maintenance</a>
                <a href={`${baseUrl}/cmms-software`}>CMMS</a>
                <a href={`${baseUrl}/work-order`}>Work Order</a>
                <a href={`${baseUrl}/use-cases/checklists-inspection`}>Checklist & Inspection</a>
                <a href={`${baseUrl}/use-cases/reporting-analytics`}>Reporting & Analytics</a>
                <a href={`${baseUrl}/use-cases/parts-inventory`}>Parts & Inventory</a>
            </div>
        </div>
        <div class="nav-dropdown">
            <a href={`${baseUrl}/industry/manufacturing`} class="nav-link">
                Industries
                <svg
                    class="chevron"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                >
                    <path
                        fill-rule="evenodd"
                        d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                        clip-rule="evenodd"></path>
                </svg>
            </a>
            <div class="dropdown-menu">
                <a href={`${baseUrl}/industry/manufacturing`}>General Manufacturing</a>
                <a href={`${baseUrl}/industry/automotives`}>Automotives</a>
                <a href={`${baseUrl}/industry/chemicals`}>Chemicals</a>
                <a href={`${baseUrl}/industry/building-materials`}>Building Materials</a>
                <a href={`${baseUrl}/industry/education-and-schools`}>Education and Schools</a>
                <a href={`${baseUrl}/industry/food-and-beverages`}>Food and Beverages</a>
                <a href={`${baseUrl}/industry/plastics`}>Plastics</a>
                <a href={`${baseUrl}/industry/retail`}>Retail</a>
            </div>
        </div>
        <a href={`${baseUrl}/pricing`} class="nav-link">Pricing</a>
        <a href={`${baseUrl}/blog`} class="nav-link">Blogs</a>
    </div>

    <div class="nav-right">
        <a href={`${appUrl}/login-route`} class="btn btn-login" target="_blank" rel="noopener">Log in</a>
        <a href={`${baseUrl}/book-demo`} class="btn btn-primary">
            Schedule Demo
            <svg class="btn-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M5 3L9 7L5 11" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </a>
    </div>

    <div class="nav-mobile-right">
        <a href={`${baseUrl}/book-demo`} class="btn btn-demo-mobile">
            Schedule Demo
            <svg class="btn-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M5 3L9 7L5 11" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </a>
        <button class="menu-toggle" aria-label="Toggle Menu">
            <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
            >
                <path
                    d="M5 7H19C19.5523 7 20 6.55228 20 6C20 5.44772 19.5523 5 19 5H5C4.44772 5 4 5.44772 4 6C4 6.55228 4.44772 7 5 7Z"
                    fill="currentColor"></path>
                <path
                    d="M5 13H19C19.5523 13 20 12.5523 20 12C20 11.4477 19.5523 11 19 11H5C4.44772 11 4 11.4477 4 12C4 12.5523 4.44772 13 5 13Z"
                    fill="currentColor"></path>
                <path
                    d="M5 19H19C19.5523 19 20 18.5523 20 18C20 17.4477 19.5523 17 19 17H5C4.44772 17 4 17.4477 4 18C4 18.5523 4.44772 19 5 19Z"
                    fill="currentColor"></path>
            </svg>
        </button>
    </div>

    <div id="mobile-menu" class="mobile-menu">
        <a href={`${baseUrl}/cmms-software`} class="nav-link mobile-link">Products</a>
        <a href={`${baseUrl}/industry/manufacturing`} class="nav-link mobile-link">Industries</a>
        <a href={`${baseUrl}/pricing`} class="nav-link mobile-link">Pricing</a>
        <a href={`${baseUrl}/blog`} class="nav-link mobile-link">Blogs</a>
        <div class="mobile-actions">
            <a href={`${appUrl}/login-route`} class="btn btn-login btn-mobile-signin" target="_blank" rel="noopener">Log in</a>
        </div>
    </div>
</nav>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const menuToggle = document.querySelector(".menu-toggle");
        const mobileMenu = document.getElementById("mobile-menu");

        menuToggle?.addEventListener("click", () => {
            mobileMenu?.classList.toggle("open");
        });
    });
</script>

<style>
    .navbar {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1.5rem;
        padding: 1rem 4rem;
        background-color: var(--color-deep-teal);
        position: relative;
        z-index: 100;
    }

    .nav-left {
        display: flex;
        align-items: center;
        justify-self: start;
    }

    .logo {
        display: flex;
        align-items: center;
        text-decoration: none;
    }

    .brand-logo {
        height: 37px;
        width: auto;
        display: block;
    }

    .nav-center {
        display: flex;
        gap: 2.25rem;
        align-items: center;
        justify-self: center;
    }

    .nav-link {
        color: var(--color-on-dark);
        text-decoration: none;
        font-family: "DM Sans", sans-serif;
        font-size: 0.95rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.25rem;
        transition: color 0.2s;
    }

    .nav-link:hover {
        color: rgba(255, 255, 255, 0.85);
    }

    .nav-dropdown {
        position: relative;
    }

    .nav-dropdown:hover .dropdown-menu {
        opacity: 1;
        visibility: visible;
    }

    .dropdown-menu {
        position: absolute;
        top: 100%;
        left: 0;
        margin-top: 0.25rem;
        min-width: 200px;
        background: var(--color-page-bg);
        border: 1px solid #eaeaea;
        border-radius: 8px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        padding: 0.5rem 0;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.2s, visibility 0.2s;
        z-index: 100;
    }

    .dropdown-menu a {
        display: block;
        padding: 0.5rem 1rem;
        color: var(--color-deep-teal);
        text-decoration: none;
        font-size: 0.9rem;
        transition: background 0.2s, color 0.2s;
    }

    .dropdown-menu a:hover {
        background: var(--color-parchment-green);
        color: var(--color-deep-teal);
    }

    .chevron {
        width: 16px;
        height: 16px;
        color: rgba(255, 255, 255, 0.75);
    }

    .nav-right {
        display: flex;
        gap: 0.875rem;
        align-items: center;
        justify-self: end;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        padding: 0.6rem 1.2rem;
        border-radius: 8px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s;
        box-sizing: border-box;
        white-space: nowrap;
    }

    .btn-login {
        color: var(--color-on-dark);
        background: var(--color-nav-login);
        border: 1px solid transparent;
    }

    .btn-login:hover {
        background: var(--color-nav-login-hover);
    }

    .btn-primary {
        color: var(--color-deep-teal);
        background: var(--color-lime-green);
        border: 1px solid transparent;
        font-weight: 600;
    }

    .btn-primary:hover {
        background: var(--color-lime-hover);
    }

    .btn-primary:active {
        background: var(--color-lime-active);
    }

    .btn-chevron {
        width: 14px;
        height: 14px;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .nav-mobile-right {
        display: none;
        align-items: center;
        gap: 0.75rem;
    }

    .btn-demo-mobile {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--color-deep-teal);
        background-color: var(--color-lime-green);
        border: 1.5px solid transparent;
        font-family: "DM Sans", sans-serif;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.6rem 1.2rem;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-demo-mobile:hover {
        background-color: var(--color-lime-hover);
    }

    .menu-toggle {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 44px;
        height: 44px;
        background-color: var(--color-nav-login);
        color: var(--color-on-dark);
        border: none;
        border-radius: 6px;
        cursor: pointer;
        padding: 0;
        transition: background-color 0.2s;
    }

    .menu-toggle:hover {
        background-color: var(--color-nav-login-hover);
    }

    .menu-toggle svg {
        width: 20px;
        height: 20px;
    }

    .mobile-menu {
        display: none;
        flex-direction: column;
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        height: 100vh;
        background-color: var(--color-deep-teal);
        padding: 1rem 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        box-sizing: border-box;
        z-index: 50;
    }

    .mobile-menu.open {
        display: flex;
    }

    .mobile-link {
        padding: 0.75rem 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        justify-content: space-between;
        color: var(--color-on-dark);
    }

    .mobile-actions {
        display: flex;
        flex-direction: column;
        margin-top: 1rem;
        padding-bottom: 1rem;
    }

    .btn-mobile-signin {
        text-align: center;
        width: 100%;
        margin-top: 1rem;
        padding: 0.75rem;
        justify-content: center;
    }

    @media screen and (max-width: 768px) {
        .navbar {
            display: flex;
            justify-content: space-between;
            padding: 1rem 1.5rem;
        }
        .nav-center,
        .nav-right {
            display: none;
        }
        .nav-mobile-right {
            display: flex;
        }
    }
</style>
