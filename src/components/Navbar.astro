---
const baseUrl = "https://opmaint.com";
const appUrl = "https://app.opmaint.com";

const productLinks = [
	{ label: "Asset Management", href: `${baseUrl}/use-cases/asset-management` },
	{ label: "Preventive Maintenance", href: `${baseUrl}/use-cases/preventive-maintenance` },
	{ label: "CMMS", href: `${baseUrl}/cmms-software` },
	{ label: "Work Order", href: `${baseUrl}/work-order` },
	{ label: "Checklist & Inspection", href: `${baseUrl}/use-cases/checklists-inspection` },
	{ label: "Reporting & Analytics", href: `${baseUrl}/use-cases/reporting-analytics` },
	{ label: "Parts & Inventory", href: `${baseUrl}/use-cases/parts-inventory` },
];

const industryLinks = [
	{ label: "General Manufacturing", href: `${baseUrl}/industry/manufacturing` },
	{ label: "Automotives", href: `${baseUrl}/industry/automotives` },
	{ label: "Chemicals", href: `${baseUrl}/industry/chemicals` },
	{ label: "Building Materials", href: `${baseUrl}/industry/building-materials` },
	{ label: "Education and Schools", href: `${baseUrl}/industry/education-and-schools` },
	{ label: "Food and Beverages", href: `${baseUrl}/industry/food-and-beverages` },
	{ label: "Plastics", href: `${baseUrl}/industry/plastics` },
	{ label: "Retail", href: `${baseUrl}/industry/retail` },
];
---

<nav class="navbar">
	<div class="nav-left">
		<a href={baseUrl} class="logo">
			<img
				src="/images/opmaint-logo-white.svg"
				alt="Opmaint"
				class="brand-logo"
				width="147"
				height="37"
			/>
		</a>
	</div>

	<div class="nav-center">
		<div class="nav-dropdown">
			<a href={`${baseUrl}/cmms-software`} class="nav-link">
				Products
				<svg class="chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
					<path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
				</svg>
			</a>
			<div class="dropdown-menu">
				{productLinks.map((link) => (
					<a href={link.href}>{link.label}</a>
				))}
			</div>
		</div>
		<div class="nav-dropdown">
			<a href={`${baseUrl}/industry/manufacturing`} class="nav-link">
				Industries
				<svg class="chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
					<path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
				</svg>
			</a>
			<div class="dropdown-menu">
				{industryLinks.map((link) => (
					<a href={link.href}>{link.label}</a>
				))}
			</div>
		</div>
		<a href={`${baseUrl}/pricing`} class="nav-link">Pricing</a>
		<a href={`${baseUrl}/blog`} class="nav-link">Blogs</a>
	</div>

	<div class="nav-right">
		<a href={`${appUrl}/login-route`} class="btn btn-login" target="_blank" rel="noopener">Log in</a>
		<a href={`${baseUrl}/book-demo`} class="btn btn-primary">
			Schedule Demo
			<svg class="btn-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
				<path d="M5 3L9 7L5 11" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
			</svg>
		</a>
	</div>

	<div class="nav-mobile-right">
		<button
			type="button"
			class="menu-toggle"
			id="menu-toggle"
			aria-label="Open menu"
			aria-expanded="false"
			aria-controls="mobile-menu"
		>
			<span class="menu-toggle-box" aria-hidden="true">
				<span class="menu-toggle-line"></span>
				<span class="menu-toggle-line"></span>
				<span class="menu-toggle-line"></span>
			</span>
		</button>
	</div>

	<div id="mobile-menu" class="mobile-menu" aria-hidden="true">
		<div class="mobile-menu-inner">
			<details class="mobile-nav-group">
				<summary class="mobile-nav-summary">
					<span>Products</span>
					<svg class="mobile-summary-chevron" width="16" height="16" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
						<path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
					</svg>
				</summary>
				<div class="mobile-subnav">
					{productLinks.map((link) => (
						<a href={link.href} class="mobile-sublink">{link.label}</a>
					))}
				</div>
			</details>

			<details class="mobile-nav-group">
				<summary class="mobile-nav-summary">
					<span>Industries</span>
					<svg class="mobile-summary-chevron" width="16" height="16" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
						<path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
					</svg>
				</summary>
				<div class="mobile-subnav">
					{industryLinks.map((link) => (
						<a href={link.href} class="mobile-sublink">{link.label}</a>
					))}
				</div>
			</details>

			<a href={`${baseUrl}/pricing`} class="mobile-link">Pricing</a>
			<a href={`${baseUrl}/blog`} class="mobile-link">Blogs</a>

			<div class="mobile-actions">
				<a href={`${appUrl}/login-route`} class="btn btn-login btn-mobile-signin" target="_blank" rel="noopener">Log in</a>
				<a href={`${baseUrl}/book-demo`} class="btn btn-primary btn-mobile-demo">
					Schedule Demo
					<svg class="btn-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
						<path d="M5 3L9 7L5 11" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</a>
			</div>
		</div>
	</div>
</nav>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const menuToggle = document.getElementById("menu-toggle");
		const mobileMenu = document.getElementById("mobile-menu");
		if (!menuToggle || !mobileMenu) return;

		const setMenuOpen = (open) => {
			mobileMenu.classList.toggle("open", open);
			menuToggle.classList.toggle("is-open", open);
			menuToggle.setAttribute("aria-expanded", open ? "true" : "false");
			menuToggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
			mobileMenu.setAttribute("aria-hidden", open ? "false" : "true");
			document.body.classList.toggle("nav-menu-open", open);
			if (!open) {
				mobileMenu.querySelectorAll("details[open]").forEach((el) => {
					el.removeAttribute("open");
				});
			}
		};

		menuToggle.addEventListener("click", (e) => {
			e.stopPropagation();
			setMenuOpen(!mobileMenu.classList.contains("open"));
		});

		mobileMenu.querySelectorAll(".mobile-link, .mobile-sublink, .mobile-actions a").forEach((link) => {
			link.addEventListener("click", () => setMenuOpen(false));
		});

		window.addEventListener("resize", () => {
			if (window.innerWidth > 768) setMenuOpen(false);
		});

		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && mobileMenu.classList.contains("open")) {
				setMenuOpen(false);
			}
		});
	});
</script>

<style>
	.navbar {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1.5rem;
		padding: 1rem 4rem;
		background-color: var(--color-deep-teal);
		position: relative;
		z-index: 200;
	}

	.nav-left {
		display: flex;
		align-items: center;
		justify-self: start;
	}

	.logo {
		display: flex;
		align-items: center;
		text-decoration: none;
	}

	.brand-logo {
		height: 37px;
		width: auto;
		display: block;
	}

	.nav-center {
		display: flex;
		gap: 2.25rem;
		align-items: center;
		justify-self: center;
	}

	.nav-link {
		color: var(--color-on-dark);
		text-decoration: none;
		font-family: "DM Sans", sans-serif;
		font-size: 0.95rem;
		font-weight: 500;
		display: flex;
		align-items: center;
		gap: 0.25rem;
		transition: color 0.2s;
	}

	.nav-link:hover {
		color: rgba(255, 255, 255, 0.85);
	}

	.nav-dropdown {
		position: relative;
	}

	.nav-dropdown:hover .dropdown-menu {
		opacity: 1;
		visibility: visible;
	}

	.dropdown-menu {
		position: absolute;
		top: 100%;
		left: 0;
		margin-top: 0.25rem;
		min-width: 200px;
		background: var(--color-page-bg);
		border: 1px solid #eaeaea;
		border-radius: 8px;
		box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
		padding: 0.5rem 0;
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.2s, visibility 0.2s;
		z-index: 100;
	}

	.dropdown-menu a {
		display: block;
		padding: 0.5rem 1rem;
		color: var(--color-deep-teal);
		text-decoration: none;
		font-size: 0.9rem;
		transition: background 0.2s, color 0.2s;
	}

	.dropdown-menu a:hover {
		background: var(--color-parchment-green);
		color: var(--color-deep-teal);
	}

	.chevron {
		width: 16px;
		height: 16px;
		color: rgba(255, 255, 255, 0.75);
	}

	.nav-right {
		display: flex;
		gap: 0.875rem;
		align-items: center;
		justify-self: end;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		padding: 0.6rem 1.2rem;
		border-radius: 8px;
		font-family: "DM Sans", sans-serif;
		font-size: 0.9rem;
		font-weight: 500;
		text-decoration: none;
		cursor: pointer;
		transition: all 0.2s;
		box-sizing: border-box;
		white-space: nowrap;
		border: none;
	}

	.btn-login {
		color: var(--color-on-dark);
		background: var(--color-nav-login);
	}

	.btn-login:hover {
		background: var(--color-nav-login-hover);
	}

	.btn-primary {
		color: var(--color-deep-teal);
		background: var(--color-lime-green);
		font-weight: 600;
	}

	.btn-primary:hover {
		background: var(--color-lime-hover);
	}

	.btn-chevron {
		width: 14px;
		height: 14px;
		flex-shrink: 0;
	}

	/* Mobile header controls */
	.nav-mobile-right {
		display: none;
		align-items: center;
		justify-self: end;
	}

	.menu-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		margin: 0;
		border: none;
		background: transparent;
		cursor: pointer;
		color: var(--color-on-dark);
		-webkit-tap-highlight-color: transparent;
	}

	.menu-toggle-box {
		position: relative;
		display: block;
		width: 44px;
		height: 44px;
		border: 1.5px solid var(--color-on-dark);
		border-radius: 4px;
		box-sizing: border-box;
	}

	.menu-toggle-line {
		position: absolute;
		left: 50%;
		width: 18px;
		height: 2px;
		margin-left: -9px;
		background-color: currentColor;
		border-radius: 1px;
		transition: transform 0.25s ease, top 0.25s ease, opacity 0.2s ease;
	}

	.menu-toggle-line:nth-child(1) {
		top: 13px;
	}

	.menu-toggle-line:nth-child(2) {
		top: 21px;
	}

	.menu-toggle-line:nth-child(3) {
		top: 29px;
	}

	.menu-toggle.is-open .menu-toggle-line:nth-child(1) {
		top: 21px;
		transform: rotate(45deg);
	}

	.menu-toggle.is-open .menu-toggle-line:nth-child(2) {
		opacity: 0;
	}

	.menu-toggle.is-open .menu-toggle-line:nth-child(3) {
		top: 21px;
		transform: rotate(-45deg);
	}

	/* Mobile menu panel */
	.mobile-menu {
		visibility: hidden;
		opacity: 0;
		pointer-events: none;
		position: fixed;
		top: 60px;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: var(--color-deep-teal);
		z-index: 150;
		overflow-y: auto;
		-webkit-overflow-scrolling: touch;
		transition: opacity 0.25s ease, visibility 0.25s ease;
	}

	.mobile-menu.open {
		visibility: visible;
		opacity: 1;
		pointer-events: auto;
	}

	.mobile-menu-inner {
		display: flex;
		flex-direction: column;
		min-height: 100%;
		padding: 0.5rem 1.25rem 2rem;
		box-sizing: border-box;
	}

	.mobile-nav-group {
		border-bottom: 1px solid rgba(255, 255, 255, 0.12);
	}

	.mobile-nav-summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 0;
		font-family: "DM Sans", sans-serif;
		font-size: 1.05rem;
		font-weight: 500;
		color: var(--color-on-dark);
		cursor: pointer;
		list-style: none;
		-webkit-tap-highlight-color: transparent;
	}

	.mobile-nav-summary::-webkit-details-marker {
		display: none;
	}

	.mobile-nav-summary::marker {
		display: none;
		content: "";
	}

	.mobile-summary-chevron {
		flex-shrink: 0;
		color: rgba(255, 255, 255, 0.75);
		transition: transform 0.2s ease;
	}

	.mobile-nav-group[open] .mobile-summary-chevron {
		transform: rotate(180deg);
	}

	.mobile-subnav {
		display: flex;
		flex-direction: column;
		padding: 0 0 0.75rem 0.5rem;
		gap: 0.15rem;
	}

	.mobile-sublink {
		display: block;
		padding: 0.55rem 0.5rem;
		font-family: "DM Sans", sans-serif;
		font-size: 0.95rem;
		font-weight: 400;
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		border-radius: 6px;
		transition: background 0.15s ease, color 0.15s ease;
	}

	.mobile-sublink:hover {
		background: rgba(255, 255, 255, 0.08);
		color: var(--color-on-dark);
	}

	.mobile-link {
		display: block;
		padding: 1rem 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.12);
		font-family: "DM Sans", sans-serif;
		font-size: 1.05rem;
		font-weight: 500;
		color: var(--color-on-dark);
		text-decoration: none;
	}

	.mobile-actions {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-top: auto;
		padding-top: 2rem;
	}

	.btn-mobile-signin,
	.btn-mobile-demo {
		width: 100%;
		justify-content: center;
		padding: 0.85rem 1.2rem;
	}

	:global(body.nav-menu-open) {
		overflow: hidden;
	}

	@media screen and (max-width: 768px) {
		.navbar {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 0.875rem 1.25rem;
			min-height: 60px;
		}

		.nav-left {
			flex: 1;
			min-width: 0;
		}

		.brand-logo {
			height: 32px;
			max-width: 130px;
		}

		.nav-center,
		.nav-right {
			display: none;
		}

		.nav-mobile-right {
			display: flex;
			flex-shrink: 0;
		}
	}
</style>
