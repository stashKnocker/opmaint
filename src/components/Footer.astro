<style>
    .footer {
        background-color: #345ebd;
        color: white;
        padding: 4rem 1.5rem 2rem;
        font-family: inherit;
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2.5rem;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .footer-column h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: white;
        font-family: "Switzer", sans-serif;
    }

    .footer-column ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer-column li {
        margin-bottom: 1rem;
    }

    .footer-column a {
        color: #ffffff;
        text-decoration: underline;
        text-underline-offset: 4px;
        text-decoration-color: rgba(255, 255, 255, 0.4);
        text-decoration-thickness: 1px;
        font-size: 0.95rem;
        transition: text-decoration-color 0.2s, color 0.2s;
        font-weight: 400;
        font-family: "DM Sans", sans-serif;
    }

    .footer-column a:hover {
        text-decoration-color: white;
    }

    .footer-divider {
        height: 1px;
        background-color: rgba(255, 255, 255, 0.2);
        width: 100%;
        margin: 2rem 0;
    }

    .footer-badges {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .store-badge {
        display: flex;
        align-items: center;
        background-color: #000;
        border: 1px solid #000;
        color: white;
        text-decoration: none;
        padding: 0.4rem 0.75rem;
        border-radius: 8px;
        gap: 0.5rem;
        min-width: 140px;
        transition: transform 0.2s;
    }

    .store-badge:hover {
        transform: translateY(-2px);
    }

    .nvidia-program {
        border-color: transparent;
        border-radius: 4px;
        min-width: 120px;
    }

    .badge-text {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
    }

    .badge-text .small {
        font-size: 0.6rem;
        font-weight: 500;
    }

    .badge-text .large {
        font-size: 1rem;
        font-weight: 600;
        font-family: "Switzer", sans-serif;
    }

    .footer-copyright {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.95rem;
        font-family: "DM Sans", sans-serif;
        color: rgba(255, 255, 255, 0.9);
        flex-wrap: wrap;
        gap: 1rem;
    }

    .social-icons {
        display: flex;
        gap: 0.75rem;
    }

    .social-btn {
        background-color: white;
        color: #345ebd;
        width: 32px;
        height: 32px;
        border-radius: 6px;
        display: flex;
        justify-content: center;
        align-items: center;
        transition: opacity 0.2s;
        text-decoration: none;
    }

    .social-btn:hover {
        opacity: 0.9;
    }

    @media screen and (max-width: 900px) {
        .footer-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media screen and (max-width: 600px) {
        .footer-grid {
            grid-template-columns: 1fr;
        }
        .footer-container {
            padding: 0;
        }
        .footer-copyright {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
