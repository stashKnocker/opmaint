---
// Footer Component – links aligned with www.opmaint.com
const baseUrl = "https://www.opmaint.com";
---

<footer class="footer">
    <div class="footer-container">
        <div class="footer-grid">
            <!-- Column 1 -->
            <div class="footer-column">
                <h3>Product</h3>
                <ul>
                    <li><a href={`${baseUrl}/use-cases/asset-management`}>Asset Management</a></li>
                    <li><a href={`${baseUrl}/use-cases/parts-inventory`}>Parts Inventory Management</a></li>
                    <li><a href={`${baseUrl}/use-cases/checklists-inspection`}>Checklists and Inspections</a></li>
                    <li><a href={`${baseUrl}/use-cases/preventive-maintenance`}>Preventive Maintenance</a></li>
                    <li><a href={`${baseUrl}/use-cases/reporting-analytics`}>Reporting</a></li>
                    <li><a href={`${baseUrl}/work-order`}>Work Order Management</a></li>
                </ul>

                <h3 style="margin-top: 2rem;">Opmaint</h3>
                <ul>
                    <li><a href={`${baseUrl}/cmms-software`}>CMMS</a></li>
                    <li><a href={`${baseUrl}/asset-management`}>Enterprise Asset Management</a></li>
                    <li><a href={`${baseUrl}/pricing`}>Pricing</a></li>
                    <li><a href={`${baseUrl}/book-demo`}>Request Demo</a></li>
                </ul>
            </div>

            <!-- Column 2 -->
            <div class="footer-column">
                <h3>Industries</h3>
                <ul>
                    <li><a href={`${baseUrl}/industry/manufacturing`}>Manufacturing Overview</a></li>
                    <li><a href={`${baseUrl}/industry/building-materials`}>Building Materials</a></li>
                    <li><a href={`${baseUrl}/industry/chemicals`}>Chemicals</a></li>
                    <li><a href={`${baseUrl}/industry/plastics`}>Plastics</a></li>
                    <li><a href={`${baseUrl}/industry/automotives`}>Automotive</a></li>
                    <li><a href={`${baseUrl}/industry/retail`}>Retail</a></li>
                    <li><a href={`${baseUrl}/industry/food-and-beverages`}>Food and Beverage</a></li>
                    <li><a href={`${baseUrl}/restaurant-management`}>Restaurants</a></li>
                    <li><a href={`${baseUrl}/industry/education-and-schools`}>Education and Schools</a></li>
                    <li><a href={`${baseUrl}/facilities-management-cmms`}>Facility Management</a></li>
                    <li><a href={baseUrl}>Property Management</a></li>
                    <li><a href={`${baseUrl}/hotel-hospitality-cmms-software`}>Hospitality</a></li>
                </ul>
            </div>

            <!-- Column 3 -->
            <div class="footer-column">
                <h3>Resources</h3>
                <ul>
                    <li><a href="/procedure">Procedure Hub</a></li>
                    <li><a href="/tools">Tools</a></li>
                    <li><a href="https://help.opmaint.com/en/" target="_blank" rel="noopener">Help Center</a></li>
                    <li><a href={`${baseUrl}/blog`}>Blog</a></li>
                    <li><a href={`${baseUrl}/calculator`}>ROI Calculator</a></li>
                    <li><a href={baseUrl}>API Documentation</a></li>
                </ul>
            </div>

            <!-- Column 4 -->
            <div class="footer-column">
                <h3>Company</h3>
                <ul>
                    <li><a href={baseUrl}>About us</a></li>
                    <li><a href="https://opmaint.zohorecruit.in/jobs/Careers" target="_blank" rel="noopener">Careers</a></li>
                    <li><a href={`${baseUrl}/terms-of-service`}>Terms of Service</a></li>
                    <li><a href={`${baseUrl}/privacy-policy`}>Privacy Policy</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-divider"></div>

        <div class="footer-badges">
            <a href="https://play.google.com/store/apps/details?hl=en_IN&id=com.opmaint.opmaint" class="badge-link" target="_blank" rel="noopener" aria-label="Get Opmaint on Google Play">
                <img
                    src="/images/img-6.webp"
                    alt="Google Play Badge"
                    class="store-badge-img"
                />
            </a>
            <a href="https://apps.apple.com/in/app/opmaint/id6502909679" class="badge-link" target="_blank" rel="noopener" aria-label="Download Opmaint on the App Store">
                <img
                    src="/images/img-7.webp"
                    alt="App Store Badge"
                    class="store-badge-img"
                />
            </a>
            <a href={baseUrl} class="badge-link">
                <img
                    src="/images/img-5.jpeg"
                    alt="WhatsApp Badge"
                    class="store-badge-img"
                />
            </a>
        </div>

        <div class="footer-divider"></div>

        <div class="footer-copyright">
            <p>&copy; 2025 Opmaint. All rights reserved.</p>
            <div class="social-icons">
                <a href="https://x.com/opmaintcmms" class="social-btn" aria-label="Follow Opmaint on X" target="_blank" rel="noopener">
                    <svg
                        viewBox="0 0 24 24"
                        width="16"
                        height="16"
                        fill="currentColor"
                        ><path
                            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                        ></path>
                    </svg>
                </a>
                <a href="https://linkedin.com/company/opmaint" class="social-btn" aria-label="Follow Opmaint on LinkedIn" target="_blank" rel="noopener">
                    <svg
                        viewBox="0 0 24 24"
                        width="16"
                        height="16"
                        fill="currentColor"
                        ><path
                            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                        ></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</footer>

<style>
    .footer {
        background-color: #345ebd;
        color: white;
        padding: 4rem 1.5rem 2rem;
        font-family: inherit;
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2.5rem;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .footer-column h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: white;
        font-family: "Switzer", sans-serif;
    }

    .footer-column ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer-column li {
        margin-bottom: 1rem;
    }

    .footer-column a {
        color: #ffffff;
        text-decoration: underline;
        text-underline-offset: 4px;
        text-decoration-color: rgba(255, 255, 255, 0.4);
        text-decoration-thickness: 1px;
        font-size: 0.95rem;
        transition: text-decoration-color 0.2s, color 0.2s;
        font-weight: 400;
        font-family: "DM Sans", sans-serif;
    }

    .footer-column a:hover {
        text-decoration-color: white;
    }

    .footer-divider {
        height: 1px;
        background-color: rgba(255, 255, 255, 0.2);
        width: 100%;
        margin: 2rem 0;
    }

    .footer-badges {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .badge-link {
        display: block;
        transition: transform 0.2s;
    }

    .badge-link:hover {
        transform: translateY(-2px);
    }

    .store-badge-img {
        height: 38px;
        width: auto;
        border-radius: 6px;
        display: block;
    }

    .footer-copyright {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.95rem;
        font-family: "DM Sans", sans-serif;
        color: rgba(255, 255, 255, 0.9);
        flex-wrap: wrap;
        gap: 1rem;
    }

    .social-icons {
        display: flex;
        gap: 0.75rem;
    }

    .social-btn {
        background-color: white;
        color: #345ebd;
        width: 32px;
        height: 32px;
        border-radius: 6px;
        display: flex;
        justify-content: center;
        align-items: center;
        transition: opacity 0.2s;
        text-decoration: none;
    }

    .social-btn:hover {
        opacity: 0.9;
    }

    @media screen and (max-width: 900px) {
        .footer-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media screen and (max-width: 600px) {
        .footer-grid {
            grid-template-columns: 1fr;
        }
        .footer-container {
            padding: 0;
        }
        .footer-copyright {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
