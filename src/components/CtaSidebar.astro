---
---

<div class="cta-sidebar-component">
    <div class="cta-card">
        <h3>Use this Procedure<br />for Free!</h3>
        <button class="cta-btn primary">Book a Demo</button>
        <button class="cta-btn outline">Start Free Trial</button>
    </div>
    <div class="cta-footer">
        <div class="download-buttons">
            <button id="download-pdf-btn" class="download-btn pdf-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                Download PDF
            </button>
            <button id="download-word-btn" class="download-btn word-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
                Download Word
            </button>
            <button id="download-excel-btn" class="download-btn excel-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="9" y1="3" x2="9" y2="21"></line>
                    <line x1="3" y1="9" x2="21" y2="9"></line>
                </svg>
                Download Excel
            </button>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const downloadPdfBtn = document.getElementById("download-pdf-btn");
        const downloadWordBtn = document.getElementById("download-word-btn");
        const downloadExcelBtn = document.getElementById("download-excel-btn");

        if (downloadPdfBtn) {
            downloadPdfBtn.addEventListener("click", async (e) => {
                e.preventDefault();
                await exportToPdf();
            });
        }

        if (downloadWordBtn) {
            downloadWordBtn.addEventListener("click", (e) => {
                e.preventDefault();
                exportToWord();
            });
        }

        if (downloadExcelBtn) {
            downloadExcelBtn.addEventListener("click", (e) => {
                e.preventDefault();
                exportToExcel();
            });
        }

        function exportToWord() {
            const title = document.querySelector('.checklist-header h1')?.textContent || 'Checklist';
            const category = document.querySelector('.category-badge')?.textContent || '';
            const description = document.querySelector('.checklist-header p')?.textContent || '';
            
            let htmlContent = `
                <html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'>
                <head>
                    <meta charset="utf-8">
                    <title>${title}</title>
                    <style>
                        body { font-family: "DM Sans", sans-serif; padding: 20px; }
                        h1 { color: #111827; }
                        .category { color: #4b5563; font-weight: bold; margin-bottom: 10px; }
                        .item { margin-bottom: 20px; }
                        .question { font-weight: bold; margin-bottom: 10px; }
                    </style>
                </head>
                <body>
                    <div class="category">${category}</div>
                    <h1>${title}</h1>
                    <p>${description}</p>
            `;

            document.querySelectorAll('.item-card').forEach((card, index) => {
                const question = card.querySelector('.item-header h3')?.textContent || '';
                const number = card.querySelector('.item-number')?.textContent || (index + 1);
                htmlContent += `<div class="item"><div class="question">${number}. ${question}</div></div>`;
            });

            htmlContent += '</body></html>';

            const blob = new Blob(['\ufeff', htmlContent], { type: 'application/msword' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `${title.replace(/[^a-z0-9]/gi, '_')}.doc`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        function exportToExcel() {
            const title = document.querySelector('.checklist-header h1')?.textContent || 'Checklist';
            const category = document.querySelector('.category-badge')?.textContent || '';
            
            let csvContent = `Category,Question Number,Question,Type\n`;
            csvContent += `${category},,${title},Header\n`;

            document.querySelectorAll('.item-card').forEach((card, index) => {
                const question = card.querySelector('.item-header h3')?.textContent || '';
                const number = card.querySelector('.item-number')?.textContent || (index + 1);
                const input = card.querySelector('.item-input');
                const type = input?.querySelector('input[type="radio"]') ? 'radio' :
                            input?.querySelector('input[type="checkbox"]') ? 'checkbox' :
                            input?.querySelector('input[type="range"]') ? 'slider' :
                            input?.querySelector('textarea') ? 'text' :
                            input?.querySelector('.stars') ? 'rating' : 'unknown';
                
                csvContent += `${category},${number},"${question.replace(/"/g, '""')}",${type}\n`;
            });

            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `${title.replace(/[^a-z0-9]/gi, '_')}.csv`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        async function exportToPdf() {
            const title = document.querySelector('.checklist-header h1')?.textContent || 'Checklist';
            const category = document.querySelector('.category-badge')?.textContent || '';
            const description = document.querySelector('.checklist-header p')?.textContent || '';

            let htmlContent = `
                <div style="font-family: 'Helvetica', 'Arial', sans-serif; padding: 24px; color: #111827; max-width: 600px; margin: 0 auto;">
                    <div style="font-size: 12px; color: #4b5563; font-weight: 600; margin-bottom: 8px; text-transform: uppercase;">${category}</div>
                    <h1 style="font-size: 24px; margin: 0 0 12px; color: #111827; border-bottom: 2px solid #eaeaea; padding-bottom: 12px;">${title}</h1>
                    <p style="font-size: 14px; color: #4b5563; line-height: 1.6; margin: 0 0 24px;">${description}</p>
                    <div style="margin-top: 24px;">
            `;

            document.querySelectorAll('.item-card').forEach((card, index) => {
                const question = card.querySelector('.item-header h3')?.textContent || '';
                const number = card.querySelector('.item-number')?.textContent || (index + 1);
                htmlContent += `
                    <div style="margin-bottom: 16px; padding: 12px 0; border-bottom: 1px solid #f3f4f6;">
                        <span style="display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; background: #ebedfa; color: #345ebd; font-weight: 700; font-size: 12px; border-radius: 50%; margin-right: 10px;">${number}</span>
                        <span style="font-size: 14px; font-weight: 600; color: #1f2937;">${question}</span>
                    </div>
                `;
            });

            htmlContent += '</div></div>';

            const container = document.createElement('div');
            container.innerHTML = htmlContent;
            container.style.position = 'absolute';
            container.style.left = '-9999px';
            container.style.top = '0';
            container.style.width = '600px';
            container.style.background = 'white';
            document.body.appendChild(container);

            try {
                const html2pdf = (await import('html2pdf.js')).default;
                const filename = `${title.replace(/[^a-z0-9]/gi, '_')}.pdf`;

                await html2pdf()
                    .set({
                        margin: 12,
                        filename,
                        image: { type: 'jpeg', quality: 0.98 },
                        html2canvas: { scale: 2, useCORS: true, letterRendering: true },
                        jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
                    })
                    .from(container)
                    .save();
            } finally {
                document.body.removeChild(container);
            }
        }
    });
</script>

<style>
    .cta-sidebar-component {
        width: 320px;
        flex-shrink: 0;
        position: sticky;
        top: 100px;
    }

    .cta-card {
        background: white;
        border: 1px solid #eaeaea;
        border-radius: 0.5rem;
        padding: 2rem 1.5rem;
        text-align: center;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        margin-bottom: 1rem;
    }

    .cta-card h3 {
        font-family: "Switzer", sans-serif;
        font-size: 1.4rem;
        font-weight: 800;
        color: #111827;
        margin: 0 0 1.5rem;
        line-height: 1.3;
    }

    .cta-btn {
        display: block;
        width: 100%;
        padding: 0.8rem 1rem;
        border-radius: 9999px;
        font-family: inherit;
        font-weight: 600;
        font-size: 1.05rem;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 1rem;
    }

    .cta-btn:last-of-type {
        margin-bottom: 0;
    }

    .cta-btn.primary {
        background: #345ebd;
        color: white;
        border: none;
    }

    .cta-btn.primary:hover {
        background: #2b4a92;
    }

    .cta-btn.outline {
        background: transparent;
        color: #345ebd;
        border: 1px solid #345ebd;
    }

    .cta-btn.outline:hover {
        background: rgba(52, 94, 189, 0.05);
    }

    .cta-footer {
        text-align: center;
        margin-top: 1rem;
    }

    .download-buttons {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .download-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-family: inherit;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid #eaeaea;
        background: white;
        color: #374151;
    }

    .download-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .pdf-btn {
        background: #dc2626;
        color: white;
        border-color: #dc2626;
    }

    .pdf-btn:hover {
        background: #b91c1c;
    }

    .word-btn {
        background: #2563eb;
        color: white;
        border-color: #2563eb;
    }

    .word-btn:hover {
        background: #1d4ed8;
    }

    .excel-btn {
        background: #16a34a;
        color: white;
        border-color: #16a34a;
    }

    .excel-btn:hover {
        background: #15803d;
    }

    @media print {
        .cta-sidebar-component {
            display: none !important;
        }
    }

    @media screen and (max-width: 900px) {
        .cta-sidebar-component {
            width: 100%;
            position: static;
            margin-top: 2rem;
        }
    }
</style>
