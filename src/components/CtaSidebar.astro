---
const baseUrl = "https://opmaint.com";
const appUrl = "https://app.opmaint.com";
/** Set in Netlify / .env as PUBLIC_CAPTURE_API_URL — never commit secrets. */
const captureApiUrl = import.meta.env.PUBLIC_CAPTURE_API_URL ?? "";
---

<div class="cta-sidebar-component">
    <div class="cta-card">
        <h3>Use this Procedure<br />for Free!</h3>
        <a href={`${baseUrl}/book-demo`} class="cta-btn primary">Book a Demo</a>
        <a href={`${appUrl}/login-route`} class="cta-btn outline" target="_blank" rel="noopener">Start Free Trial</a>
    </div>
    <div class="cta-footer">
        <div class="download-buttons">
            <button id="download-pdf-btn" class="download-btn pdf-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                Download PDF
            </button>
            <button id="download-excel-btn" class="download-btn excel-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="9" y1="3" x2="9" y2="21"></line>
                    <line x1="3" y1="9" x2="21" y2="9"></line>
                </svg>
                Download Excel
            </button>
        </div>
    </div>
</div>

<!-- Email capture (step 1) then download (step 2) — step 2 keeps a fresh user gesture so PDF/CSV downloads are not blocked -->
<div
    id="pdf-email-modal"
    class="pdf-email-modal"
    aria-hidden="true"
    role="dialog"
    aria-labelledby="pdf-email-modal-title"
    data-capture-url={captureApiUrl}
>
    <div class="pdf-email-modal__backdrop" data-close-modal></div>
    <div class="pdf-email-modal__panel">
        <button type="button" class="pdf-email-modal__close" data-close-modal aria-label="Close">&times;</button>
        <div id="pdf-modal-step-email" class="pdf-email-modal__step">
            <h2 id="pdf-email-modal-title" class="pdf-email-modal__title">Download as PDF</h2>
            <p id="pdf-email-modal-intro" class="pdf-email-modal__intro">To download this checklist as a PDF, please enter your work email address.</p>
            <label class="pdf-email-modal__label" for="pdf-email-input">Work email</label>
            <input
                id="pdf-email-input"
                class="pdf-email-modal__input"
                type="email"
                name="work-email"
                autocomplete="email"
                placeholder="name@company.com"
                inputmode="email"
            />
            <p id="pdf-email-error" class="pdf-email-modal__error" role="alert"></p>
            <p class="pdf-email-modal__hint">We won't send you any spam, we promise!</p>
            <button type="button" id="pdf-email-submit" class="pdf-email-modal__submit pdf-email-modal__submit--secondary">
                <span id="pdf-email-submit-inner" class="pdf-email-modal__submit-inner"></span>
            </button>
        </div>
        <div id="pdf-modal-step-download" class="pdf-email-modal__step pdf-email-modal__step--hidden" aria-hidden="true">
            <h2 class="pdf-email-modal__title" id="pdf-modal-download-heading">Ready to download</h2>
            <p id="pdf-modal-download-intro" class="pdf-email-modal__intro"></p>
            <button type="button" id="pdf-modal-final-download" class="pdf-email-modal__submit">
                <span id="pdf-modal-final-download-inner" class="pdf-email-modal__submit-inner"></span>
            </button>
        </div>
    </div>
</div>

<script>
    import { jsPDF } from "jspdf";

    function getCaptureEndpoint() {
        return (
            document.getElementById("pdf-email-modal")?.getAttribute("data-capture-url")?.trim() ?? ""
        );
    }

    /** Domains treated as personal/free — work email should use a corporate domain. */
    const FREE_EMAIL_DOMAINS = new Set([
        "gmail.com",
        "googlemail.com",
        "yahoo.com",
        "yahoo.co.uk",
        "hotmail.com",
        "outlook.com",
        "live.com",
        "msn.com",
        "icloud.com",
        "me.com",
        "aol.com",
        "protonmail.com",
        "proton.me",
        "mail.com",
        "gmx.com",
        "yandex.com",
        "zoho.com",
        "hey.com",
        "fastmail.com",
    ]);

    function isValidEmailFormat(email) {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.trim());
    }

    function isWorkEmail(email) {
        const trimmed = email.trim().toLowerCase();
        if (!isValidEmailFormat(trimmed)) return false;
        const domain = trimmed.split("@")[1];
        if (!domain) return false;
        return !FREE_EMAIL_DOMAINS.has(domain);
    }

    const PDF_DOWNLOAD_BTN_HTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg> Download checklist PDF`;
    const EXCEL_DOWNLOAD_BTN_HTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line><line x1="3" y1="9" x2="21" y2="9"></line></svg> Download checklist Excel`;
    const STEP1_CONTINUE_HTML = "Continue";

    let pendingExport = "pdf";

    function setDownloadModalMode(format) {
        pendingExport = format;
        const titleEl = document.getElementById("pdf-email-modal-title");
        const introEl = document.getElementById("pdf-email-modal-intro");
        const innerEl = document.getElementById("pdf-email-submit-inner");
        if (titleEl) {
            titleEl.textContent = format === "pdf" ? "Download as PDF" : "Download as Excel";
        }
        if (introEl) {
            introEl.textContent =
                format === "pdf"
                    ? "To download this checklist as a PDF, please enter your work email address."
                    : "To download this checklist as Excel (CSV), please enter your work email address.";
        }
        if (innerEl) {
            innerEl.textContent = STEP1_CONTINUE_HTML;
        }
    }

    function resetModalSteps() {
        const emailStep = document.getElementById("pdf-modal-step-email");
        const dlStep = document.getElementById("pdf-modal-step-download");
        emailStep?.classList.remove("pdf-email-modal__step--hidden");
        dlStep?.classList.add("pdf-email-modal__step--hidden");
        if (dlStep) dlStep.setAttribute("aria-hidden", "true");
    }

    function showDownloadStep() {
        const emailStep = document.getElementById("pdf-modal-step-email");
        const dlStep = document.getElementById("pdf-modal-step-download");
        const intro = document.getElementById("pdf-modal-download-intro");
        const inner = document.getElementById("pdf-modal-final-download-inner");
        if (intro) {
            intro.textContent =
                pendingExport === "pdf"
                    ? "Your email was saved. Click below to download your checklist as a PDF."
                    : "Your email was saved. Click below to download your checklist as Excel (CSV).";
        }
        if (inner) {
            inner.innerHTML =
                pendingExport === "pdf" ? PDF_DOWNLOAD_BTN_HTML : EXCEL_DOWNLOAD_BTN_HTML;
        }
        emailStep?.classList.add("pdf-email-modal__step--hidden");
        dlStep?.classList.remove("pdf-email-modal__step--hidden");
        if (dlStep) dlStep.setAttribute("aria-hidden", "false");
        setTimeout(() => document.getElementById("pdf-modal-final-download")?.focus(), 50);
    }

    function openDownloadEmailModal(format) {
        resetModalSteps();
        setDownloadModalMode(format);
        const modal = document.getElementById("pdf-email-modal");
        const input = document.getElementById("pdf-email-input");
        const err = document.getElementById("pdf-email-error");
        if (!modal) return;
        modal.classList.add("pdf-email-modal--open");
        modal.setAttribute("aria-hidden", "false");
        if (err) err.textContent = "";
        if (input) {
            input.value = "";
            setTimeout(() => input.focus(), 50);
        }
    }

    function closePdfModal() {
        const modal = document.getElementById("pdf-email-modal");
        if (!modal) return;
        modal.classList.remove("pdf-email-modal--open");
        modal.setAttribute("aria-hidden", "true");
        resetModalSteps();
    }

    async function submitCaptureThenPdf(email) {
        const endpoint = getCaptureEndpoint();
        if (!endpoint) {
            throw new Error("Download is not configured. Please try again later.");
        }
        const localPart = email.split("@")[0]?.replace(/[^a-zA-Z0-9._-]/g, "_") || null;
        const body = {
            email: email.trim().toLowerCase(),
            ipaddress: null,
            username: localPart || null,
        };
        const res = await fetch(endpoint, {
            method: "POST",
            headers: { "Content-Type": "application/json", Accept: "application/json" },
            body: JSON.stringify(body),
            mode: "cors",
            credentials: "omit",
        });
        if (!res.ok) {
            const t = await res.text().catch(() => "");
            throw new Error(t || `Request failed (${res.status})`);
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        const downloadPdfBtn = document.getElementById("download-pdf-btn");
        const downloadExcelBtn = document.getElementById("download-excel-btn");
        const modal = document.getElementById("pdf-email-modal");
        const submitBtn = document.getElementById("pdf-email-submit");
        const emailInput = document.getElementById("pdf-email-input");
        const errEl = document.getElementById("pdf-email-error");
        const finalDownloadBtn = document.getElementById("pdf-modal-final-download");

        modal?.querySelectorAll("[data-close-modal]").forEach((el) => {
            el.addEventListener("click", () => closePdfModal());
        });

        if (downloadPdfBtn) {
            downloadPdfBtn.addEventListener("click", async (e) => {
                e.preventDefault();
                openDownloadEmailModal("pdf");
            });
        }

        if (downloadExcelBtn) {
            downloadExcelBtn.addEventListener("click", (e) => {
                e.preventDefault();
                openDownloadEmailModal("excel");
            });
        }

        setDownloadModalMode("pdf");

        submitBtn?.addEventListener("click", async () => {
            const email = emailInput?.value?.trim() || "";
            if (errEl) errEl.textContent = "";
            if (!email) {
                if (errEl) errEl.textContent = "Please enter your work email.";
                return;
            }
            if (!isWorkEmail(email)) {
                if (errEl)
                    errEl.textContent =
                        "Please use a work email (not a personal provider like Gmail or Yahoo).";
                return;
            }
            submitBtn.setAttribute("disabled", "true");
            try {
                await submitCaptureThenPdf(email);
                showDownloadStep();
            } catch (e) {
                if (errEl)
                    errEl.textContent =
                        e instanceof Error
                            ? e.message
                            : "Could not save your email. Please try again.";
            } finally {
                submitBtn.removeAttribute("disabled");
            }
        });

        emailInput?.addEventListener("keydown", (e) => {
            if (e.key === "Enter") {
                e.preventDefault();
                submitBtn?.click();
            }
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && modal?.classList.contains("pdf-email-modal--open")) {
                closePdfModal();
            }
        });

        function exportToExcel() {
            const title = document.querySelector('.checklist-header h1')?.textContent || 'Checklist';
            const category = document.querySelector('.category-badge')?.textContent || '';
            
            let csvContent = `Category,Question Number,Question,Type\n`;
            csvContent += `${category},,${title},Header\n`;

            document.querySelectorAll('.item-card').forEach((card, index) => {
                const question = card.querySelector('.item-header h3')?.textContent || '';
                const number = card.querySelector('.item-number')?.textContent || (index + 1);
                const input = card.querySelector('.item-input');
                const type = input?.querySelector('input[type="radio"]') ? 'radio' :
                            input?.querySelector('input[type="checkbox"]') ? 'checkbox' :
                            input?.querySelector('input[type="range"]') ? 'slider' :
                            input?.querySelector('textarea') ? 'text' :
                            input?.querySelector('.stars') ? 'rating' : 'unknown';
                
                csvContent += `${category},${number},"${question.replace(/"/g, '""')}",${type}\n`;
            });

            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `${title.replace(/[^a-z0-9]/gi, '_')}.csv`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        /** Synchronous PDF build + save — call from a click handler (imported jsPDF constructor) */
        function buildAndSavePdf(JsPDF) {
            const title = document.querySelector('.checklist-header h1')?.textContent?.trim() || 'Checklist';
            const category = document.querySelector('.category-badge')?.textContent?.trim() || '';
            const description = document.querySelector('.checklist-header p')?.textContent?.trim() || '';

            const items = [];
            document.querySelectorAll('.item-card').forEach((card, index) => {
                const question = card.querySelector('.item-header h3')?.textContent?.trim() || '';
                const numberEl = card.querySelector('.item-number');
                const number = numberEl ? parseInt(numberEl.textContent || '0', 10) : index + 1;
                const options = [];
                let type;
                let extra;
                const radioOpts = card.querySelectorAll('.options-group.radio .radio-text');
                const checkboxOpts = card.querySelectorAll('.options-group.checkbox .checkbox-text');
                const sliderLabels = card.querySelectorAll('.options-group.slider .slider-labels span');
                const ratingEl = card.querySelector('.options-group.rating');
                const textInput = card.querySelector('.text-input');
                if (radioOpts.length) {
                    type = 'radio';
                    radioOpts.forEach((el) => {
                        const text = el.textContent?.trim();
                        if (text) options.push(text);
                    });
                } else if (checkboxOpts.length) {
                    type = 'checkbox';
                    checkboxOpts.forEach((el) => {
                        const text = el.textContent?.trim();
                        if (text) options.push(text);
                    });
                } else if (sliderLabels.length) {
                    type = 'slider';
                    sliderLabels.forEach((el) => {
                        const text = el.textContent?.trim();
                        if (text) options.push(text);
                    });
                } else if (ratingEl) {
                    type = 'rating';
                    extra = 'Rating: 1 to 5';
                } else if (textInput) {
                    type = 'text';
                    extra = textInput.placeholder || 'Enter details...';
                }
                items.push({ number, question, options: options.length ? options : undefined, type, extra });
            });

            const doc = new JsPDF({ unit: 'mm', format: 'a4', orientation: 'portrait' });
            doc.setCharSpace(0);
            const pageW = doc.internal.pageSize.getWidth();
            const pageH = doc.internal.pageSize.getHeight();
            const margin = 20;
            const footerReserve = 14;
            const maxW = pageW - margin * 2;
            const lineH = 5;
            const optLineH = 4;
            let y = margin;

            const addPageIfNeeded = (needed) => {
                if (y + needed > pageH - margin - footerReserve) {
                    doc.addPage();
                    y = margin;
                }
            };

            // Native PDF wordmark (SVG/canvas→PNG often renders invisible in jsPDF)
            doc.setFontSize(17);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(4, 54, 61);
            doc.text('Opmaint', margin, y);
            y += 4;
            doc.setDrawColor(4, 54, 61);
            doc.setLineWidth(0.35);
            doc.line(margin, y, margin + 34, y);
            y += 8;

            if (category) {
                doc.setFontSize(10);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(75, 85, 99);
                doc.text(category.toUpperCase(), margin, y);
                y += 7;
            }

            doc.setFontSize(18);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(17, 24, 39);
            const titleLines = doc.splitTextToSize(title, maxW);
            doc.text(titleLines, margin, y);
            y += titleLines.length * 7 + 4;

            if (description) {
                doc.setFontSize(11);
                doc.setFont('helvetica', 'normal');
                doc.setTextColor(75, 85, 99);
                const descLines = doc.splitTextToSize(description, maxW);
                addPageIfNeeded(descLines.length * lineH);
                doc.text(descLines, margin, y);
                y += descLines.length * lineH + 8;
            }

            doc.setDrawColor(234, 234, 234);
            doc.line(margin, y, pageW - margin, y);
            y += 10;

            doc.setFontSize(12);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(31, 41, 55);

            items.forEach(({ number, question, options, type, extra }) => {
                const questionText = `${number}. ${question}`;
                const questionLines = doc.splitTextToSize(questionText, maxW - 12);
                addPageIfNeeded(questionLines.length * lineH + 2);
                doc.text(questionLines, margin + 6, y);
                y += questionLines.length * lineH + 2;
                if (options?.length) {
                    doc.setFont('helvetica', 'normal');
                    doc.setFontSize(10);
                    doc.setTextColor(80, 90, 100);
                    const prefix = type === 'radio' ? '( ) ' : type === 'checkbox' ? '[ ] ' : '';
                    options.forEach((opt) => {
                        const optText = prefix ? prefix + opt : opt;
                        const optLines = doc.splitTextToSize(optText, maxW - 20);
                        addPageIfNeeded(optLines.length * optLineH + 1);
                        doc.text(optLines, margin + 14, y);
                        y += optLines.length * optLineH + 1;
                    });
                    doc.setFont('helvetica', 'bold');
                    doc.setFontSize(12);
                    doc.setTextColor(31, 41, 55);
                    y += 2;
                } else if (extra) {
                    doc.setFont('helvetica', 'normal');
                    doc.setFontSize(10);
                    doc.setTextColor(80, 90, 100);
                    const hintText = type === 'text' ? '[ ' + extra + ' ]' : extra;
                    const hintLines = doc.splitTextToSize(hintText, maxW - 20);
                    addPageIfNeeded(hintLines.length * optLineH + 1);
                    doc.text(hintLines, margin + 14, y);
                    y += hintLines.length * optLineH + 4;
                    doc.setFont('helvetica', 'bold');
                    doc.setFontSize(12);
                    doc.setTextColor(31, 41, 55);
                }
            });

            const totalPages = doc.getNumberOfPages();
            for (let p = 1; p <= totalPages; p++) {
                doc.setPage(p);
                doc.setFontSize(8);
                doc.setFont('helvetica', 'normal');
                doc.setTextColor(120, 120, 120);
                doc.text('Opmaint · opmaint.com', pageW / 2, pageH - 8, { align: 'center' });
            }

            const filename = `${title.replace(/[^a-z0-9]/gi, '_')}.pdf`;
            doc.save(filename);
        }

        finalDownloadBtn?.addEventListener("click", () => {
            try {
                if (pendingExport === "pdf") {
                    buildAndSavePdf(jsPDF);
                } else {
                    exportToExcel();
                }
            } catch (err) {
                console.error(err);
            }
            closePdfModal();
        });
    });
</script>

<style>
    .pdf-email-modal {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        box-sizing: border-box;
    }

    .pdf-email-modal--open {
        display: flex;
    }

    .pdf-email-modal__backdrop {
        position: absolute;
        inset: 0;
        background: rgba(17, 24, 39, 0.45);
        cursor: pointer;
    }

    .pdf-email-modal__panel {
        position: relative;
        width: 100%;
        max-width: 420px;
        background: #fff;
        border-radius: 12px;
        padding: 1.75rem 1.5rem 1.5rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.2);
        font-family: "DM Sans", sans-serif;
    }

    .pdf-email-modal__step--hidden {
        display: none !important;
    }

    .pdf-email-modal__submit--secondary {
        background: #fff;
        color: var(--color-sage-green);
        border: 2px solid var(--color-deep-teal);
    }

    .pdf-email-modal__submit--secondary:hover:not(:disabled) {
        background: var(--color-brand-focus-subtle);
    }

    .pdf-email-modal__close {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        width: 2rem;
        height: 2rem;
        border: none;
        background: transparent;
        font-size: 1.5rem;
        line-height: 1;
        color: #6b7280;
        cursor: pointer;
        border-radius: 6px;
    }

    .pdf-email-modal__close:hover {
        background: var(--color-parchment-green);
        color: #111827;
    }

    .pdf-email-modal__title {
        font-family: "Switzer", sans-serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: #111827;
        margin: 0 0 0.75rem;
        padding-right: 2rem;
    }

    .pdf-email-modal__intro {
        font-size: 0.95rem;
        color: #4b5563;
        margin: 0 0 1rem;
        line-height: 1.5;
    }

    .pdf-email-modal__label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.35rem;
    }

    .pdf-email-modal__input {
        width: 100%;
        box-sizing: border-box;
        padding: 0.65rem 0;
        border: none;
        border-bottom: 2px solid var(--color-deep-teal);
        font-size: 1rem;
        font-family: inherit;
        background: transparent;
        color: #111827;
        margin-bottom: 0.35rem;
    }

    .pdf-email-modal__input:focus {
        outline: none;
        border-bottom-color: var(--color-lime-hover);
    }

    .pdf-email-modal__input::placeholder {
        color: #9ca3af;
    }

    .pdf-email-modal__error {
        min-height: 1.25rem;
        font-size: 0.8rem;
        color: #b91c1c;
        margin: 0 0 0.5rem;
    }

    .pdf-email-modal__hint {
        font-size: 0.8rem;
        color: #9ca3af;
        margin: 0 0 1.25rem;
    }

    .pdf-email-modal__submit-inner {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .pdf-email-modal__submit {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        padding: 0.85rem 1rem;
        border: none;
        border-radius: 9999px;
        background: var(--color-lime-green);
        color: var(--color-on-lime);
        font-family: inherit;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: background 0.2s;
    }

    .pdf-email-modal__submit:hover:not(:disabled) {
        background: var(--color-lime-hover);
    }

    .pdf-email-modal__submit:disabled {
        opacity: 0.65;
        cursor: not-allowed;
    }

    .cta-sidebar-component {
        width: 320px;
        flex-shrink: 0;
        position: sticky;
        top: 100px;
    }

    .cta-card {
        background: white;
        border: 1px solid #eaeaea;
        border-radius: 0.5rem;
        padding: 2rem 1.5rem;
        text-align: center;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        margin-bottom: 1rem;
    }

    .cta-card h3 {
        font-family: "Switzer", sans-serif;
        font-size: 1.4rem;
        font-weight: 800;
        color: #111827;
        margin: 0 0 1.5rem;
        line-height: 1.3;
    }

    .cta-btn {
        display: block;
        width: 100%;
        padding: 0.8rem 1rem;
        border-radius: 9999px;
        font-family: inherit;
        font-weight: 600;
        font-size: 1.05rem;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 1rem;
        text-decoration: none;
        text-align: center;
        box-sizing: border-box;
    }

    .cta-btn:last-of-type {
        margin-bottom: 0;
