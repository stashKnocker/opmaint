<div class="cta-sidebar-component">
    <div class="cta-card">
        <h3>Use this Procedure<br />for Free!</h3>
        <button class="cta-btn primary">Book a Demo</button>
        <button class="cta-btn outline">Start Free Trial</button>
    </div>
    <div class="cta-footer">
        <a href="#" id="download-pdf-btn" class="pdf-link"
            >Download as PDF &darr;</a
        >
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const downloadBtn = document.getElementById("download-pdf-btn");
        if (downloadBtn) {
            downloadBtn.addEventListener("click", (e) => {
                e.preventDefault();
                window.print();
            });
        }
    });
</script>

<style>
    .cta-sidebar-component {
        width: 320px;
        flex-shrink: 0;
        position: sticky;
        top: 100px;
    }

    .cta-card {
        background: white;
        border: 1px solid #eaeaea;
        border-radius: 0.5rem;
        padding: 2rem 1.5rem;
        text-align: center;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        margin-bottom: 1rem;
    }

    .cta-card h3 {
        font-size: 1.4rem;
        font-weight: 800;
        color: #111827;
        margin: 0 0 1.5rem;
        line-height: 1.3;
    }

    .cta-btn {
        display: block;
        width: 100%;
        padding: 0.8rem 1rem;
        border-radius: 9999px;
        font-family: inherit;
        font-weight: 600;
        font-size: 1.05rem;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 1rem;
    }

    .cta-btn:last-of-type {
        margin-bottom: 0;
    }

    .cta-btn.primary {
        background: #345ebd;
        color: white;
        border: none;
    }

    .cta-btn.primary:hover {
        background: #2b4a92;
    }

    .cta-btn.outline {
        background: transparent;
        color: #345ebd;
        border: 1px solid #345ebd;
    }

    .cta-btn.outline:hover {
        background: rgba(52, 94, 189, 0.05);
    }

    .cta-footer {
        text-align: center;
        margin-top: 1rem;
    }

    .pdf-link {
        color: #6b7280;
        text-decoration: none;
        font-size: 1.1rem;
        font-weight: 500;
        transition: color 0.2s;
        background: none;
        border: none;
        cursor: pointer;
        font-family: inherit;
        padding: 0;
    }

    .pdf-link:hover {
        color: #374151;
    }

    @media print {
        .cta-sidebar-component {
            display: none !important;
        }
    }

    @media screen and (max-width: 900px) {
        .cta-sidebar-component {
            width: 100%;
            position: static;
            margin-top: 2rem;
        }
    }
</style>
