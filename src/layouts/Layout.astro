---
import Analytics from "../components/Analytics.astro";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import "../styles/theme.css";
import "../styles/pages.css";

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	/** Comma-separated keywords (e.g. from SEO sheet). */
	keywords?: string;
	image?: string;
	noindex?: boolean;
	/** Hide navbar and footer (e.g. standalone landing pages). */
	bare?: boolean;
	/** Additional JSON-LD object(s); merged as extra script tag(s). Strings are escaped for HTML. */
	extraJsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title = "Opmaint - Maintenance Procedures & Tools",
	description = "Maintenance procedures, checklists, calculators, and tools for operations. OEE, MTTR, MTBF, downtime calculators. Free resources for maintenance professionals.",
	canonical,
	keywords,
	image,
	noindex = false,
	bare = false,
	extraJsonLd,
} = Astro.props;

const site = Astro.site?.toString() ?? "https://opmaint.com";
const canonicalUrl = (
	canonical
		? canonical.startsWith("http")
			? canonical
			: new URL(canonical, site).toString()
		: new URL(Astro.url.pathname, site).toString()
).replace(/^http:\/\//, "https://");
const imageUrl = image
	? image.startsWith("http")
		? image
		: new URL(image.startsWith("/") ? image : `/${image}`, site).toString()
	: new URL("/images/img-4.png", site).toString();
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="facebook-domain-verification" content="w5565ofxpkjezewm79e8zaatijyek3" />
		<link rel="icon" type="image/png" href="/images/img-3.png" sizes="32x32" />
		<link rel="apple-touch-icon" href="/images/img-4.png" sizes="180x180" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		{keywords && <meta name="keywords" content={keywords} />}
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:site_name" content="Opmaint" />
		<meta property="og:locale" content="en_US" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		<link
			href="https://api.fontshare.com/v2/css?f[]=switzer@400,500,600,700&display=swap"
			rel="stylesheet"
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "Opmaint",
			"url": site,
			"description": "Maintenance procedures, checklists, and tools for operations.",
		}).replace(/</g, "\\u003c")} />
		{extraJsonLd &&
			(Array.isArray(extraJsonLd) ? extraJsonLd : [extraJsonLd]).map((block) => (
				<script
					type="application/ld+json"
					set:html={JSON.stringify(block).replace(/</g, "\\u003c")}
				/>
			))}
		<Analytics />
	</head>
	<body class:list={{ "layout--bare": bare }}>
		<!-- Google Tag Manager (noscript) -->
		<noscript
			><iframe
				src="https://www.googletagmanager.com/ns.html?id=GTM-N3W75D35"
				height="0"
				width="0"
				style="display:none;visibility:hidden"></iframe></noscript
		>
		<!-- Meta Pixel Code (noscript) -->
		<noscript
			><img
				height="1"
				width="1"
				style="display:none"
				src="https://www.facebook.com/tr?id=27357310600621512&ev=PageView&noscript=1"
				alt="" /></noscript
		>
		{!bare && <Navbar />}
		<slot />
		{!bare && <Footer />}
		<style>
			html,
			body {
				margin: 0;
				width: 100%;
				min-height: 100%;
				font-family: "DM Sans", sans-serif;
				background-color: var(--color-page-bg);
				color: var(--color-deep-teal);
			}
			h1, h2, h3, h4, h5, h6 {
				font-family: "Switzer", sans-serif;
			}
			p,
			span,
			li,
			blockquote {
				font-family: "DM Sans", sans-serif;
			}
		</style>
	</body>
</html>
