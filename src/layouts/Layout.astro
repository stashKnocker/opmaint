---
import Footer from "../components/Footer.astro";

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	image?: string;
	noindex?: boolean;
}

const {
	title = "Opmaint - Maintenance Procedures & Tools",
	description = "Maintenance procedures, checklists, calculators, and tools for operations. OEE, MTTR, MTBF, downtime calculators. Free resources for maintenance professionals.",
	canonical,
	image,
	noindex = false,
} = Astro.props;

const site = Astro.site?.toString() ?? "https://opmaint.com";
const canonicalUrl = canonical
	? canonical.startsWith("http")
		? canonical
		: new URL(canonical, site).toString()
	: new URL(Astro.url.pathname, site).toString();
const imageUrl = image
	? image.startsWith("http")
		? image
		: new URL(image.startsWith("/") ? image : `/${image}`, site).toString()
	: new URL("/img-4.png", site).toString();
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/img-3.png" sizes="32x32" />
		<link rel="apple-touch-icon" href="/img-4.png" sizes="180x180" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:site_name" content="Opmaint" />
		<meta property="og:locale" content="en_US" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		<link
			href="https://api.fontshare.com/v2/css?f[]=switzer@400,500,600,700&display=swap"
			rel="stylesheet"
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "Opmaint",
			"url": site,
			"description": "Maintenance procedures, checklists, and tools for operations.",
		})} />
	</head>
	<body>
		<slot />
		<Footer />
		<style>
			html,
			body {
				margin: 0;
				width: 100%;
				height: 100%;
				font-family: "DM Sans", sans-serif;
			}
			h1, h2, h3, h4, h5, h6 {
				font-family: "Switzer", sans-serif;
			}
			p,
			span,
			li,
			blockquote {
				font-family: "DM Sans", sans-serif;
			}
		</style>
	</body>
</html>
