# Do not commit a real .env file. Set these in Netlify → Site settings → Environment variables.

# Webflow CMS API (blog). Server-side only.
WEBFLOW_API_KEY=
WEBFLOW_BLOG_COLLECTION_ID=
WEBFLOW_TOPIC_COLLECTION_ID=
WEBFLOW_INDUSTRY_COLLECTION_ID=

# Webflow form submission API key (read submissions via Data API; optional).
WEBFLOW_FORM_API_KEY=

# Webflow form POST target (server-side v1 submit from /api/webflow-form-submit).
# Example: Book Demo Form on opmaint.com/book-demo
WEBFLOW_SITE_ID=
WEBFLOW_FORM_NAME=
WEBFLOW_FORM_PAGE_ID=
WEBFLOW_FORM_ELEMENT_ID=
WEBFLOW_FORM_PAGE_URL=

# Public URL for checklist download email capture (POST JSON).
PUBLIC_CAPTURE_API_URL=
